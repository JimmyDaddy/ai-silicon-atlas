---
import BaseLayout from "../layouts/BaseLayout.astro";
import { companies } from "../data/companies";
import { deltaSnapshot } from "../data/delta";
import { healthSnapshot, healthStatusLabel } from "../data/health";
import { stageByKey, type StageKey } from "../data/stages";
import { themes } from "../data/themes";
import { formatDate } from "../data/updates";
import { sitePath } from "../lib/paths";

const companyBySlug = Object.fromEntries(companies.map((company) => [company.slug, company]));
const metricNames: Record<string, string> = { revenue: "收入", netIncome: "净利润", assets: "资产", cash: "现金", capex: "资本开支" };
const formatValue = (value: number | null, unit = "") => {
  if (value === null) return "—";
  const formatted = new Intl.NumberFormat("zh-CN", { notation: "compact", maximumFractionDigits: 2 }).format(value);
  return unit === "USD" ? `US$${formatted}` : `${formatted} ${unit}`.trim();
};
const affectedStages = Object.entries(deltaSnapshot.affected.stages)
  .sort((left, right) => right[1] - left[1])
  .map(([key, count]) => ({ stage: stageByKey[key as StageKey], count }))
  .filter((item) => item.stage);
const affectedThemes = themes.map((theme) => ({
  theme,
  score: theme.stages.reduce((score, stage) => score + (deltaSnapshot.affected.stages[stage] ?? 0), 0),
})).filter((item) => item.score > 0).sort((left, right) => right.score - left.score);
const hasCompanyChanges = deltaSnapshot.companies.filings.length + deltaSnapshot.companies.metrics.length + deltaSnapshot.companies.statuses.length + deltaSnapshot.companies.analysis.length > 0;
const statusLabel = (value: { status: string; stale: boolean } | null) => {
  if (!value) return "无上一版";
  if (value.stale) return "上版快照";
  if (value.status === "ok") return "自动数据最新";
  if (value.status === "manual") return "人工维护";
  if (value.status === "unconfigured") return "待配置";
  return value.status;
};
const hasNewsChanges = deltaSnapshot.intelligence.new.length + deltaSnapshot.intelligence.analysisRefreshed.length > 0;
---

<BaseLayout title="变化雷达 · 智芯图谱" description="查看 AI 与半导体产业链自上一批次以来新增的披露、指标、权威情报和 AI 分析变化。" active="radar">
  <section class="page-hero radar-hero">
    <div class="shell page-hero-grid">
      <div>
        <span class="eyebrow">Daily change radar</span>
        <h1 class="display-title">不重读全站，<br />只看<em>发生了什么</em></h1>
      </div>
      <div>
        <p class="page-kicker">比较连续数据快照，把新增披露、指标变化、权威情报和 AI 分析刷新压缩成一条可核验的变化流。</p>
        <div class="page-meta"><span><i></i>{deltaSnapshot.summary.totalChanges} 项变化</span><span>{formatDate(deltaSnapshot.period.from)} → {formatDate(deltaSnapshot.period.to)}</span></div>
      </div>
    </div>
  </section>

  <section class="radar-overview section-rule">
    <div class="shell">
      <div class={`health-banner ${healthSnapshot.overall}`}>
        <div><span>DATA HEALTH</span><strong>{healthStatusLabel[healthSnapshot.overall]}</strong></div>
        <p>{healthSnapshot.companies.fresh} 家公司数据新鲜 · {healthSnapshot.companies.stale} 家使用上一版 · 权威情报独立来源占比 {(healthSnapshot.intelligence.independentShare * 100).toFixed(0)}%</p>
        <a href={sitePath("/updates/")}>查看详情 ↗</a>
      </div>

      <div class="radar-metrics">
        <article><span>01</span><strong>{deltaSnapshot.summary.newFilings}</strong><p>新增官方披露</p></article>
        <article><span>02</span><strong>{deltaSnapshot.summary.metricChanges}</strong><p>指标快照变化</p></article>
        <article><span>03</span><strong>{deltaSnapshot.summary.newIntelligence}</strong><p>新增权威情报</p></article>
        <article><span>04</span><strong>{deltaSnapshot.summary.companyAnalysisRefreshes + deltaSnapshot.summary.intelligenceAnalysisRefreshes}</strong><p>AI 分析刷新</p></article>
      </div>

      <div class="radar-controls">
        <div>
          <span class="eyebrow">Personal view</span>
          <p>关注列表只保存在当前浏览器中，不会上传。</p>
        </div>
        <div class="control-actions">
          <button type="button" class="active" data-radar-scope="all" aria-pressed="true">全部变化</button>
          <button type="button" data-radar-scope="watchlist" aria-pressed="false">只看我的关注 <span data-watch-count>0</span></button>
          <a href={sitePath("/companies/")}>管理关注列表 ↗</a>
        </div>
      </div>
      <div class="empty-state" data-radar-empty>当前批次没有与你关注公司直接关联的变化。</div>
    </div>
  </section>

  {deltaSnapshot.summary.totalChanges === 0 && (
    <section class="section"><div class="shell"><div class="quiet-state"><span>NO MATERIAL DELTA</span><h2>本批次没有结构化变化</h2><p>这不表示产业没有变化，只表示与上一版快照相比，尚未发现新的官方披露、指标或情报条目。</p></div></div></section>
  )}

  {hasCompanyChanges && (
    <section class="section section-rule" data-radar-section>
      <div class="shell">
        <div class="section-head"><div><span class="eyebrow">Company evidence</span><h2 class="section-title">公司证据变化</h2><p class="section-copy">事实变化与 AI 推断分开呈现；点击公司或披露可回到完整证据。</p></div></div>

        {deltaSnapshot.companies.filings.length > 0 && <div class="change-list">
          {deltaSnapshot.companies.filings.map((filing) => {
            const company = companyBySlug[filing.company];
            return <a class="change-row" data-radar-item data-companies={filing.company} href={filing.url} target="_blank" rel="noreferrer"><span class="change-kind">NEW FILING</span><div><strong>{company?.name ?? filing.company}</strong><p>{filing.title}</p></div><div><b>{filing.form}</b><small>{filing.filedAt}</small></div><i>↗</i></a>;
          })}
        </div>}

        {deltaSnapshot.companies.metrics.length > 0 && <div class="metric-change-grid">
          {deltaSnapshot.companies.metrics.map((metric) => {
            const company = companyBySlug[metric.company];
            return <a class="metric-change" data-radar-item data-companies={metric.company} href={sitePath(`/companies/${metric.company}/`)}>
              <span>{company?.name ?? metric.company} · {metricNames[metric.metric] ?? metric.metric}</span>
              <strong>{formatValue(metric.value, metric.unit)}</strong>
              <p>{metric.previousValue === null ? "首次获得该指标" : `上一版 ${formatValue(metric.previousValue, metric.unit)}`} · 截至 {metric.periodEnd}</p>
              {metric.changePercent !== null && <b class:list={[{ up: metric.changePercent >= 0 }]}>{metric.changePercent >= 0 ? "+" : ""}{metric.changePercent.toFixed(1)}%</b>}
            </a>;
          })}
        </div>}

        {deltaSnapshot.companies.statuses.length > 0 && <div class="status-change-grid">
          {deltaSnapshot.companies.statuses.map((status) => {
            const company = companyBySlug[status.company];
            return <a class="status-change" data-radar-item data-companies={status.company} href={sitePath(`/companies/${status.company}/`)}>
              <span>DATA STATUS</span>
              <h3>{company?.name ?? status.company}</h3>
              <p><i>{statusLabel(status.from)}</i><b>→</b><strong>{statusLabel(status.to)}</strong></p>
              <small>查看最新披露与指标 ↗</small>
            </a>;
          })}
        </div>}

        {deltaSnapshot.companies.analysis.length > 0 && <div class="analysis-change-grid">
          {deltaSnapshot.companies.analysis.map((analysis) => {
            const company = companyBySlug[analysis.company];
            return <a class="analysis-change" data-radar-item data-companies={analysis.company} href={sitePath(`/companies/${analysis.company}/`)}><span>AI SYNTHESIS · {analysis.confidence ?? "LOW"}</span><h3>{company?.name ?? analysis.company}</h3><p>{analysis.summary}</p><i>查看证据 ↗</i></a>;
          })}
        </div>}
      </div>
    </section>
  )}

  {hasNewsChanges && (
    <section class="section section-rule intelligence-delta" data-radar-section>
      <div class="shell">
        <div class="section-head"><div><span class="eyebrow">Intelligence delta</span><h2 class="section-title">情报与分析刷新</h2><p class="section-copy">新增文章保留原文链接；已有文章只在 AI 分析状态真正变化时出现。</p></div><a class="text-link" href={sitePath("/news/")}>打开完整时间线 <span>→</span></a></div>
        <div class="intelligence-change-grid">
          {deltaSnapshot.intelligence.new.map((article) => <a class="intelligence-change" data-radar-item data-companies={article.relatedCompanies.join("|")} href={article.sourceUrl} target="_blank" rel="noreferrer"><div><span>{article.sourceType}</span><time>{formatDate(article.publishedAt)}</time></div><strong>{article.source}</strong><h3>{article.title}</h3><p>{article.summary}</p><footer>{article.topics.slice(0, 3).map((topic) => <i>{topic}</i>)}<b>↗</b></footer></a>)}
          {deltaSnapshot.intelligence.analysisRefreshed.map((article) => <a class="intelligence-change refreshed" data-radar-item data-companies={article.relatedCompanies.join("|")} href={sitePath(`/news/#${article.id}`)}><div><span>AI ANALYSIS REFRESHED</span><time>{formatDate(article.generatedAt)}</time></div><strong>{article.source}</strong><h3>{article.title}</h3><footer><i>查看综合分析</i><b>→</b></footer></a>)}
        </div>
      </div>
    </section>
  )}

  {(affectedStages.length > 0 || affectedThemes.length > 0) && <section class="section section-rule"><div class="shell impact-layout">
    <div><span class="eyebrow">Affected chain</span><h2 class="section-title">变化落在哪些环节</h2><div class="impact-list">{affectedStages.map(({ stage, count }) => <a href={sitePath(`/map/#${stage.key}`)}><span>{stage.index}</span><strong>{stage.name}</strong><b>{count}</b></a>)}</div></div>
    <div><span class="eyebrow">Research lenses</span><h2 class="section-title">关联研究主题</h2><div class="impact-list">{affectedThemes.map(({ theme, score }, index) => <a href={sitePath(`/research/#${theme.slug}`)}><span>{String(index + 1).padStart(2, "0")}</span><strong>{theme.title}</strong><b>{score}</b></a>)}</div></div>
  </div></section>}

  <script>
    const storageKey = "silicon-atlas-watchlist-v1";
    const scopeButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-radar-scope]")];
    const radarItems = [...document.querySelectorAll<HTMLElement>("[data-radar-item]")];
    const radarSections = [...document.querySelectorAll<HTMLElement>("[data-radar-section]")];
    const empty = document.querySelector<HTMLElement>("[data-radar-empty]");
    const count = document.querySelector<HTMLElement>("[data-watch-count]");

    const readWatchlist = () => {
      try {
        const value = JSON.parse(localStorage.getItem(storageKey) ?? "[]");
        return new Set<string>(Array.isArray(value) ? value : []);
      } catch { return new Set<string>(); }
    };

    const applyScope = (scope: string) => {
      const watchlist = readWatchlist();
      let visible = 0;
      if (count) count.textContent = String(watchlist.size);
      radarItems.forEach((item) => {
        const related = (item.dataset.companies ?? "").split("|").filter(Boolean);
        const show = scope === "all" || related.some((slug) => watchlist.has(slug));
        item.hidden = !show;
        if (show) visible += 1;
      });
      radarSections.forEach((section) => {
        section.hidden = ![...section.querySelectorAll<HTMLElement>("[data-radar-item]")].some((item) => !item.hidden);
      });
      empty?.classList.toggle("visible", scope === "watchlist" && visible === 0);
    };

    scopeButtons.forEach((button) => button.addEventListener("click", () => {
      scopeButtons.forEach((candidate) => {
        const active = candidate === button;
        candidate.classList.toggle("active", active);
        candidate.setAttribute("aria-pressed", String(active));
      });
      applyScope(button.dataset.radarScope ?? "all");
    }));
    applyScope("all");
  </script>
</BaseLayout>

<style>
  .radar-hero { background: radial-gradient(circle at 78% 48%, rgba(83, 213, 245, 0.11), transparent 27rem); }
  .radar-overview { padding: 2rem 0 5rem; }
  .health-banner { align-items: center; background: rgba(99, 230, 190, 0.045); border: 1px solid rgba(99, 230, 190, 0.24); border-radius: 1rem; display: grid; gap: 1.2rem; grid-template-columns: 11rem 1fr auto; padding: 1rem 1.2rem; }
  .health-banner.degraded { background: rgba(245, 185, 113, 0.045); border-color: rgba(245, 185, 113, 0.24); }
  .health-banner.critical { background: rgba(251, 113, 133, 0.045); border-color: rgba(251, 113, 133, 0.24); }
  .health-banner > div { display: grid; gap: 0.25rem; }
  .health-banner span { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.64rem; }
  .health-banner strong { color: var(--mint); }
  .health-banner.degraded strong { color: var(--amber); }
  .health-banner.critical strong { color: var(--rose); }
  .health-banner p { color: var(--text-muted); font-size: 0.82rem; margin: 0; }
  .health-banner a { color: var(--text-muted); font-size: 0.76rem; text-decoration: none; }
  .radar-metrics { border-left: 1px solid var(--line); border-top: 1px solid var(--line); display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 1rem; }
  .radar-metrics article { border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); display: grid; min-height: 11rem; padding: 1rem; }
  .radar-metrics span { color: var(--mint); font-family: var(--font-mono); font-size: 0.64rem; }
  .radar-metrics strong { align-self: end; font-family: var(--font-display); font-size: 2.8rem; font-weight: 500; }
  .radar-metrics p { color: var(--text-muted); font-size: 0.8rem; margin: 0.3rem 0 0; }
  .radar-controls { align-items: center; border-bottom: 1px solid var(--line); display: flex; gap: 2rem; justify-content: space-between; padding: 1.2rem 0; }
  .radar-controls p { color: var(--text-dim); font-size: 0.76rem; margin: 0.35rem 0 0; }
  .control-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .control-actions button, .control-actions a { background: transparent; border: 1px solid var(--line); border-radius: 999px; color: var(--text-muted); font-size: 0.76rem; padding: 0.55rem 0.75rem; text-decoration: none; }
  .control-actions button.active { background: rgba(99, 230, 190, 0.1); border-color: rgba(99, 230, 190, 0.4); color: var(--text-strong); }
  .control-actions span { color: var(--mint); }
  .quiet-state { border: 1px dashed var(--line-strong); border-radius: 1rem; padding: 3rem; }
  .quiet-state > span, .change-kind { color: var(--mint); font-family: var(--font-mono); font-size: 0.64rem; }
  .quiet-state h2 { font-family: var(--font-display); font-size: 2rem; font-weight: 500; margin: 1rem 0 0.6rem; }
  .quiet-state p { color: var(--text-muted); margin: 0; }
  .change-list { border-top: 1px solid var(--line); }
  .change-row { align-items: center; border-bottom: 1px solid var(--line); color: var(--text-muted); display: grid; gap: 1rem; grid-template-columns: 7rem 1fr auto 1rem; padding: 1rem 0; text-decoration: none; }
  .change-row > div { display: grid; gap: 0.25rem; }
  .change-row strong { color: var(--text-strong); }
  .change-row p, .change-row small { color: var(--text-dim); font-size: 0.76rem; margin: 0; }
  .change-row b { color: var(--mint); font-family: var(--font-mono); }
  .change-row i { color: var(--mint); font-style: normal; }
  .metric-change-grid, .status-change-grid, .analysis-change-grid, .intelligence-change-grid { display: grid; gap: 0.8rem; grid-template-columns: repeat(3, 1fr); margin-top: 1rem; }
  .metric-change, .status-change, .analysis-change, .intelligence-change { background: var(--surface-soft); border: 1px solid var(--line); border-radius: 0.9rem; color: var(--text-muted); display: grid; min-height: 13rem; padding: 1rem; position: relative; text-decoration: none; }
  .metric-change > span, .analysis-change > span { color: var(--text-dim); font-size: 0.7rem; }
  .metric-change > strong { align-self: center; color: var(--text-strong); font-family: var(--font-display); font-size: 2rem; font-weight: 500; }
  .metric-change p, .analysis-change p { font-size: 0.78rem; line-height: 1.65; margin: 0; }
  .metric-change > b { bottom: 1rem; color: var(--rose); position: absolute; right: 1rem; }
  .metric-change > b.up { color: var(--mint); }
  .status-change { min-height: 10rem; }
  .status-change > span { color: var(--mint); font-family: var(--font-mono); font-size: 0.64rem; }
  .status-change h3 { align-self: end; color: var(--text-strong); font-family: var(--font-display); font-size: 1.45rem; font-weight: 500; margin: 1rem 0 0; }
  .status-change p { align-items: center; display: flex; flex-wrap: wrap; font-size: 0.72rem; gap: 0.5rem; margin: 0.5rem 0; }
  .status-change p i { color: var(--text-dim); font-style: normal; }
  .status-change p b { color: var(--text-dim); }
  .status-change p strong { color: var(--mint); }
  .status-change small { color: var(--text-dim); }
  .analysis-change h3 { color: var(--text-strong); font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; margin: 1.5rem 0 0.8rem; }
  .analysis-change i { align-self: end; color: var(--mint); font-size: 0.74rem; font-style: normal; margin-top: 1rem; }
  .intelligence-delta { background: linear-gradient(180deg, rgba(83, 213, 245, 0.025), transparent); }
  .intelligence-change { min-height: 20rem; }
  .intelligence-change > div, .intelligence-change footer { align-items: center; display: flex; gap: 0.6rem; justify-content: space-between; }
  .intelligence-change > div { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.64rem; }
  .intelligence-change > strong { color: var(--cyan); font-size: 0.72rem; margin-top: 1.2rem; }
  .intelligence-change h3 { color: var(--text-strong); font-family: var(--font-display); font-size: 1.35rem; font-weight: 500; line-height: 1.35; margin: 0.8rem 0; }
  .intelligence-change p { font-size: 0.82rem; line-height: 1.7; margin: 0; }
  .intelligence-change footer { align-self: end; border-top: 1px solid var(--line); flex-wrap: wrap; margin-top: 1rem; padding-top: 0.8rem; }
  .intelligence-change footer i { border: 1px solid var(--line); border-radius: 999px; color: var(--text-dim); font-size: 0.64rem; font-style: normal; padding: 0.3rem 0.45rem; }
  .intelligence-change footer b { color: var(--mint); margin-left: auto; }
  .intelligence-change.refreshed { min-height: 13rem; }
  .impact-layout { display: grid; gap: 5rem; grid-template-columns: 1fr 1fr; }
  .impact-layout .section-title { font-size: 2.2rem; }
  .impact-list { border-top: 1px solid var(--line); margin-top: 1.5rem; }
  .impact-list a { align-items: center; border-bottom: 1px solid var(--line); color: var(--text-muted); display: grid; gap: 1rem; grid-template-columns: 2rem 1fr auto; padding: 0.8rem 0; text-decoration: none; }
  .impact-list span { color: var(--mint); font-family: var(--font-mono); font-size: 0.64rem; }
  .impact-list b { color: var(--text-dim); font-family: var(--font-mono); }
  [data-radar-item][hidden], [data-radar-section][hidden] { display: none; }
  @media (max-width: 900px) { .metric-change-grid, .status-change-grid, .analysis-change-grid, .intelligence-change-grid { grid-template-columns: repeat(2, 1fr); } .health-banner { grid-template-columns: 1fr auto; } .health-banner p { grid-column: 1 / -1; grid-row: 2; } }
  @media (max-width: 680px) { .radar-metrics { grid-template-columns: repeat(2, 1fr); } .radar-controls { align-items: flex-start; flex-direction: column; } .control-actions { width: 100%; } .metric-change-grid, .status-change-grid, .analysis-change-grid, .intelligence-change-grid, .impact-layout { grid-template-columns: 1fr; } .change-row { align-items: start; grid-template-columns: 1fr auto; } .change-kind { grid-column: 1 / -1; } .change-row > i { display: none; } .health-banner { grid-template-columns: 1fr; } .health-banner p { grid-column: 1; grid-row: auto; } }
</style>
