---
import BaseLayout from "../layouts/BaseLayout.astro";
import { companies } from "../data/companies";
import { newsArticles, newsDisplayTitle } from "../data/news";
import { stageByKey } from "../data/stages";
import { indicatorTypeLabels, themes, type ResearchTheme } from "../data/themes";
import { formatDate } from "../data/updates";
import { sitePath } from "../lib/paths";

function relatedNews(theme: ResearchTheme) {
  return newsArticles
    .map((article) => {
      const text = `${article.title} ${article.titleZh ?? ""} ${article.topics.join(" ")}`.toLowerCase();
      const stageScore = article.relatedStages.filter((stage) => theme.stages.includes(stage as never)).length * 2;
      const keywordScore = theme.newsKeywords.filter((keyword) => text.includes(keyword.toLowerCase())).length * 3;
      return { article, score: stageScore + keywordScore };
    })
    .filter((item) => item.score > 0)
    .sort((left, right) => right.score - left.score || right.article.publishedAt.localeCompare(left.article.publishedAt))
    .slice(0, 3)
    .map((item) => item.article);
}
---

<BaseLayout title="研究主题 · 智芯图谱" description="以关键问题、传导机制、指标和情景组织 AI 与半导体产业链研究。" active="research">
  <section class="page-hero research-hero">
    <div class="shell page-hero-grid">
      <div>
        <span class="eyebrow">Research lenses</span>
        <h1 class="display-title">少追新闻，<br />多看<em>传导机制</em></h1>
      </div>
      <div>
        <p class="page-kicker">每个主题都从一个可验证的问题开始，沿传导链连接领先指标、确认信号、反证条件和代表公司。</p>
        <div class="page-meta"><span><i></i>{themes.length} 个研究主题</span><span>{themes.reduce((count, theme) => count + theme.indicators.length, 0)} 个跟踪指标</span><span>交互式情景推演</span></div>
      </div>
    </div>
  </section>

  <nav class="theme-jump" aria-label="研究主题快速导航">
    <div class="shell">
      {themes.map((theme, index) => <a href={`#${theme.slug}`}><span>{String(index + 1).padStart(2, "0")}</span>{theme.title}</a>)}
    </div>
  </nav>

  <section class="themes-list">
    <div class="shell">
      {themes.map((theme, index) => {
        const relatedCompanies = companies.filter((company) => theme.stages.includes(company.stage)).slice(0, 6);
        const articles = relatedNews(theme);
        return (
          <article id={theme.slug} class={`theme-study ${theme.tone}`} data-theme-study>
            <header class="theme-heading">
              <div class="theme-index">{String(index + 1).padStart(2, "0")}</div>
              <div class="theme-title-block">
                <span class="theme-eyebrow">{theme.eyebrow}</span>
                <h2>{theme.title}</h2>
                <p>{theme.summary}</p>
              </div>
              <blockquote>{theme.question}</blockquote>
            </header>

            <div class="theme-thesis">
              <span>RESEARCH THESIS</span>
              <p>{theme.thesis}</p>
            </div>

            <section class="mechanism-section">
              <div class="subsection-head">
                <div><span>TRANSMISSION MAP</span><h3>价值如何传导</h3></div>
                <small>从需求起点到报表兑现</small>
              </div>
              <div class="mechanism-flow">
                {theme.mechanism.map((step, stepIndex) => (
                  <article>
                    <div><span>{String(stepIndex + 1).padStart(2, "0")}</span>{stepIndex < theme.mechanism.length - 1 && <i>→</i>}</div>
                    <h4>{step.label}</h4>
                    <p>{step.description}</p>
                  </article>
                ))}
              </div>
            </section>

            <details class="theme-workbench" open={index === 0}>
              <summary>
                <span><i></i>打开研究工作台</span>
                <small>{theme.indicators.length} INDICATORS · {theme.scenarios.length} SCENARIOS</small>
              </summary>
              <div class="workbench-body">
                <section class="indicator-lab" data-indicator-lab>
                  <div class="subsection-head">
                    <div><span>SIGNAL DASHBOARD</span><h3>观察指标</h3></div>
                    <small>点击筛选信号角色</small>
                  </div>
                  <div class="indicator-filters" role="group" aria-label={`${theme.title}指标筛选`}>
                    <button type="button" class="active" data-indicator-filter="all" aria-pressed="true">全部</button>
                    {Object.entries(indicatorTypeLabels).map(([key, label]) => <button type="button" data-indicator-filter={key} aria-pressed="false">{label}</button>)}
                  </div>
                  <div class="indicator-grid">
                    {theme.indicators.map((indicator) => (
                      <article class={`indicator-card ${indicator.type}`} data-indicator-card={indicator.type}>
                        <div><span>{indicatorTypeLabels[indicator.type]}</span><i></i></div>
                        <h4>{indicator.label}</h4>
                        <p>{indicator.description}</p>
                        <aside><strong>如何解读</strong>{indicator.interpretation}</aside>
                      </article>
                    ))}
                  </div>
                </section>

                <section class="scenario-lab" data-scenario-lab>
                  <div class="subsection-head">
                    <div><span>SCENARIO LAB</span><h3>情景压力测试</h3></div>
                    <small>切换假设，查看传导结果</small>
                  </div>
                  <div class="scenario-tabs" role="tablist" aria-label={`${theme.title}情景`}>
                    {theme.scenarios.map((scenario) => (
                      <button
                        type="button"
                        role="tab"
                        data-scenario-button={scenario.key}
                        aria-selected={scenario.key === "base" ? "true" : "false"}
                      >{scenario.label}</button>
                    ))}
                  </div>
                  <div class="scenario-panels">
                    {theme.scenarios.map((scenario) => (
                      <article data-scenario-panel={scenario.key} hidden={scenario.key !== "base"}>
                        <span>TRIGGER</span>
                        <p>{scenario.trigger}</p>
                        <strong>可能的产业影响</strong>
                        <ul>{scenario.implications.map((implication) => <li>{implication}</li>)}</ul>
                      </article>
                    ))}
                  </div>
                </section>

                <div class="evidence-grid">
                  <section>
                    <span class="micro-label">QUESTIONS TO VERIFY</span>
                    <h3>下一步核验什么</h3>
                    <ol>{theme.verification.map((question, questionIndex) => <li><i>{String(questionIndex + 1).padStart(2, "0")}</i><span>{question}</span></li>)}</ol>
                  </section>
                  <section>
                    <span class="micro-label">LATEST EVIDENCE</span>
                    <h3>相关权威情报</h3>
                    <div class="theme-news-list">
                      {articles.map((article) => (
                        <a href={article.url} target="_blank" rel="noreferrer">
                          <div><strong>{article.sourceName}</strong><time>{formatDate(article.publishedAt)}</time></div>
                          <span>{newsDisplayTitle(article)}</span><i>↗</i>
                        </a>
                      ))}
                    </div>
                  </section>
                </div>
              </div>
            </details>

            <footer class="theme-relations">
              <div>
                <span class="micro-label">VALUE CHAIN</span>
                <div class="stage-list">{theme.stages.map((key) => <a href={sitePath(`/map/#${key}`)}>{stageByKey[key].name}</a>)}</div>
              </div>
              <div>
                <span class="micro-label">REPRESENTATIVE COMPANIES</span>
                <div class="company-list">{relatedCompanies.map((company) => <a href={sitePath(`/companies/${company.slug}/`)}>{company.name}<span>{company.ticker}</span></a>)}</div>
              </div>
            </footer>
          </article>
        );
      })}
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>("[data-indicator-lab]").forEach((lab) => {
      const buttons = [...lab.querySelectorAll<HTMLButtonElement>("[data-indicator-filter]")];
      const cards = [...lab.querySelectorAll<HTMLElement>("[data-indicator-card]")];
      buttons.forEach((button) => button.addEventListener("click", () => {
        const selected = button.dataset.indicatorFilter ?? "all";
        buttons.forEach((candidate) => {
          const active = candidate === button;
          candidate.classList.toggle("active", active);
          candidate.setAttribute("aria-pressed", String(active));
        });
        cards.forEach((card) => { card.hidden = selected !== "all" && card.dataset.indicatorCard !== selected; });
      }));
    });

    document.querySelectorAll<HTMLElement>("[data-scenario-lab]").forEach((lab) => {
      const buttons = [...lab.querySelectorAll<HTMLButtonElement>("[data-scenario-button]")];
      const panels = [...lab.querySelectorAll<HTMLElement>("[data-scenario-panel]")];
      buttons.forEach((button) => button.addEventListener("click", () => {
        const selected = button.dataset.scenarioButton;
        buttons.forEach((candidate) => candidate.setAttribute("aria-selected", String(candidate === button)));
        panels.forEach((panel) => { panel.hidden = panel.dataset.scenarioPanel !== selected; });
      }));
    });
  </script>
</BaseLayout>

<style>
  .research-hero { background: radial-gradient(circle at 76% 62%, rgba(245, 185, 113, 0.075), transparent 23rem); }

  .theme-jump {
    background: rgba(7, 16, 29, 0.9);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 4.8rem;
    z-index: 20;
  }

  .theme-jump .shell {
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    padding-block: 0.7rem;
    scrollbar-width: none;
  }

  .theme-jump a {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-muted);
    flex: 0 0 auto;
    font-size: 0.8rem;
    padding: 0.52rem 0.7rem;
    text-decoration: none;
  }

  .theme-jump a:hover { border-color: rgba(99, 230, 190, 0.4); color: var(--text-strong); }
  .theme-jump a span { color: var(--mint); font-family: var(--font-mono); font-size: 0.62rem; margin-right: 0.4rem; }
  .themes-list { padding: 1rem 0 4rem; }

  .theme-study {
    --theme-color: var(--cyan);
    border-top: 1px solid var(--line-strong);
    padding: clamp(4rem, 8vw, 7rem) 0;
    scroll-margin-top: 9rem;
  }

  .theme-study.amber { --theme-color: var(--amber); }
  .theme-study.violet { --theme-color: var(--violet); }

  .theme-heading {
    align-items: start;
    display: grid;
    gap: 2rem;
    grid-template-columns: 3rem minmax(0, 1fr) minmax(18rem, 0.7fr);
  }

  .theme-index { color: var(--theme-color); font-family: var(--font-mono); font-size: 0.72rem; padding-top: 0.5rem; }
  .theme-eyebrow { color: var(--theme-color); font-size: 0.78rem; }
  .theme-title-block h2 { font-family: var(--font-display); font-size: clamp(2.4rem, 5vw, 4.4rem); font-weight: 500; letter-spacing: -0.05em; line-height: 1.04; margin: 0.6rem 0 1rem; }
  .theme-title-block > p { color: var(--text-muted); font-size: 0.94rem; line-height: 1.8; margin: 0; max-width: 42rem; }
  .theme-heading blockquote { border-left: 1px solid var(--theme-color); color: var(--text-strong); font-family: var(--font-display); font-size: 1.25rem; line-height: 1.55; margin: 0.4rem 0 0; padding-left: 1.2rem; }

  .theme-thesis {
    background: linear-gradient(110deg, color-mix(in srgb, var(--theme-color) 7%, transparent), transparent 72%);
    border: 1px solid color-mix(in srgb, var(--theme-color) 22%, var(--line));
    border-radius: 1rem;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 10rem 1fr;
    margin: 2.5rem 0 0 5rem;
    padding: 1.25rem;
  }

  .theme-thesis span,
  .subsection-head > div > span,
  .micro-label {
    color: var(--theme-color);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.09em;
  }

  .theme-thesis p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.85; margin: 0; }
  .mechanism-section { margin: 3.5rem 0 0 5rem; }

  .subsection-head { align-items: end; display: flex; gap: 2rem; justify-content: space-between; }
  .subsection-head h3 { font-family: var(--font-display); font-size: 2rem; font-weight: 500; margin: 0.35rem 0 0; }
  .subsection-head > small { color: var(--text-dim); font-size: 0.78rem; }

  .mechanism-flow {
    border-bottom: 1px solid var(--line);
    border-left: 1px solid var(--line);
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 1.2rem;
  }

  .mechanism-flow article { border-right: 1px solid var(--line); min-height: 12rem; padding: 1rem; }
  .mechanism-flow article > div { align-items: center; color: var(--theme-color); display: flex; font-family: var(--font-mono); font-size: 0.66rem; justify-content: space-between; }
  .mechanism-flow article > div i { color: var(--text-dim); font-style: normal; }
  .mechanism-flow h4 { font-family: var(--font-display); font-size: 1.35rem; font-weight: 500; margin: 2.5rem 0 0.55rem; }
  .mechanism-flow p { color: var(--text-muted); font-size: 0.82rem; line-height: 1.7; margin: 0; }

  .theme-workbench { border-bottom: 1px solid var(--line-strong); border-top: 1px solid var(--line-strong); margin: 3rem 0 0 5rem; }
  .theme-workbench > summary { align-items: center; cursor: pointer; display: flex; gap: 1rem; justify-content: space-between; list-style: none; padding: 1rem 0; }
  .theme-workbench > summary::-webkit-details-marker { display: none; }
  .theme-workbench > summary > span { align-items: center; color: var(--text-strong); display: inline-flex; font-size: 0.84rem; gap: 0.65rem; }
  .theme-workbench > summary > span i { border-bottom: 1px solid var(--theme-color); border-right: 1px solid var(--theme-color); height: 0.45rem; transform: rotate(45deg); transition: transform 160ms ease; width: 0.45rem; }
  .theme-workbench[open] > summary > span i { transform: rotate(225deg); }
  .theme-workbench > summary small { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.66rem; }
  .workbench-body { border-top: 1px solid var(--line); padding: 2.5rem 0 1rem; }
  .scenario-lab { margin-top: 4rem; }

  .indicator-filters,
  .scenario-tabs { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1.2rem; }

  .indicator-filters button,
  .scenario-tabs button {
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.8rem;
    padding: 0.55rem 0.75rem;
  }

  .indicator-filters button:hover,
  .indicator-filters button.active,
  .scenario-tabs button:hover,
  .scenario-tabs button[aria-selected="true"] { background: color-mix(in srgb, var(--theme-color) 10%, transparent); border-color: color-mix(in srgb, var(--theme-color) 45%, var(--line)); color: var(--text-strong); }

  .indicator-grid { display: grid; gap: 0.7rem; grid-template-columns: repeat(2, minmax(0, 1fr)); margin-top: 1rem; }
  .indicator-card { background: rgba(255, 255, 255, 0.025); border: 1px solid var(--line); border-radius: 0.85rem; padding: 1rem; }
  .indicator-card[hidden] { display: none; }
  .indicator-card > div { align-items: center; color: var(--text-dim); display: flex; font-family: var(--font-mono); font-size: 0.64rem; justify-content: space-between; }
  .indicator-card > div i { background: var(--theme-color); border-radius: 50%; height: 0.35rem; width: 0.35rem; }
  .indicator-card.risk > div i { background: var(--rose); }
  .indicator-card h4 { font-size: 0.94rem; margin: 1.15rem 0 0.45rem; }
  .indicator-card > p { color: var(--text-muted); font-size: 0.8rem; line-height: 1.65; margin: 0; }
  .indicator-card aside { border-top: 1px solid var(--line); color: var(--text-muted); font-size: 0.82rem; line-height: 1.65; margin-top: 0.9rem; padding-top: 0.8rem; }
  .indicator-card aside strong { color: var(--theme-color); display: block; font-family: var(--font-mono); font-size: 0.62rem; font-weight: 500; margin-bottom: 0.35rem; }

  .scenario-panels { margin-top: 1rem; }
  .scenario-panels article { background: linear-gradient(120deg, color-mix(in srgb, var(--theme-color) 7%, transparent), transparent); border: 1px solid color-mix(in srgb, var(--theme-color) 22%, var(--line)); border-radius: 0.9rem; padding: 1.2rem; }
  .scenario-panels article[hidden] { display: none; }
  .scenario-panels article > span { color: var(--theme-color); font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.08em; }
  .scenario-panels article > p { color: var(--text-strong); font-family: var(--font-display); font-size: 1.1rem; line-height: 1.55; margin: 0.65rem 0 1.2rem; }
  .scenario-panels article > strong { color: var(--text-dim); font-size: 0.78rem; }
  .scenario-panels ul { display: grid; gap: 0.55rem; list-style: none; margin: 0.7rem 0 0; padding: 0; }
  .scenario-panels li { color: var(--text-muted); font-size: 0.84rem; line-height: 1.6; padding-left: 1rem; position: relative; }
  .scenario-panels li::before { color: var(--theme-color); content: "→"; left: 0; position: absolute; }

  .evidence-grid { display: grid; gap: 3rem; grid-template-columns: 1fr 1fr; margin-top: 4rem; }
  .evidence-grid h3 { font-family: var(--font-display); font-size: 1.65rem; font-weight: 500; margin: 0.5rem 0 1rem; }
  .evidence-grid ol { border-top: 1px solid var(--line); list-style: none; margin: 0; padding: 0; }
  .evidence-grid ol li { align-items: start; border-bottom: 1px solid var(--line); display: grid; gap: 0.8rem; grid-template-columns: 2rem 1fr; padding: 0.85rem 0; }
  .evidence-grid ol i { color: var(--theme-color); font-family: var(--font-mono); font-size: 0.64rem; font-style: normal; padding-top: 0.1rem; }
  .evidence-grid ol span { color: var(--text-muted); font-size: 0.84rem; line-height: 1.6; }
  .theme-news-list { border-top: 1px solid var(--line); }
  .theme-news-list a { border-bottom: 1px solid var(--line); color: var(--text-muted); display: grid; gap: 0.45rem; grid-template-columns: 1fr auto; padding: 0.75rem 0; text-decoration: none; }
  .theme-news-list a:hover { color: var(--text-strong); }
  .theme-news-list a > div { display: flex; gap: 0.7rem; grid-column: 1 / -1; }
  .theme-news-list strong { color: var(--theme-color); font-size: 0.68rem; }
  .theme-news-list time { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.64rem; }
  .theme-news-list a > span { font-size: 0.84rem; line-height: 1.5; }
  .theme-news-list a > i { color: var(--theme-color); font-style: normal; }

  .theme-relations { display: grid; gap: 3rem; grid-template-columns: 0.65fr 1.35fr; margin: 3rem 0 0 5rem; }
  .stage-list { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.8rem; }
  .stage-list a { border: 1px solid var(--line); border-radius: 999px; color: var(--text-muted); font-size: 0.76rem; padding: 0.42rem 0.6rem; text-decoration: none; }
  .stage-list a:hover { border-color: color-mix(in srgb, var(--theme-color) 40%, var(--line)); color: var(--text-strong); }
  .company-list { display: grid; gap: 0.45rem; grid-template-columns: repeat(3, 1fr); margin-top: 0.8rem; }
  .company-list a { align-items: center; border: 1px solid var(--line); border-radius: 0.65rem; color: var(--text-muted); display: flex; font-size: 0.8rem; justify-content: space-between; padding: 0.65rem; text-decoration: none; }
  .company-list a:hover { border-color: color-mix(in srgb, var(--theme-color) 40%, var(--line)); color: var(--text-strong); }
  .company-list span { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.62rem; }

  @media (max-width: 900px) {
    .theme-heading { grid-template-columns: 2rem 1fr; }
    .theme-heading blockquote { grid-column: 2; }
    .theme-thesis,
    .mechanism-section,
    .theme-workbench,
    .theme-relations { margin-left: 4rem; }
    .mechanism-flow { grid-template-columns: repeat(2, 1fr); }
    .theme-relations { grid-template-columns: 1fr; }
  }

  @media (max-width: 680px) {
    .theme-jump { top: 4.2rem; }
    .theme-study { scroll-margin-top: 8rem; }
    .theme-heading { gap: 1rem; grid-template-columns: 1fr; }
    .theme-heading blockquote { grid-column: auto; }
    .theme-thesis,
    .mechanism-section,
    .theme-workbench,
    .theme-relations { margin-left: 0; }
    .theme-thesis { gap: 0.65rem; grid-template-columns: 1fr; }
    .mechanism-flow,
    .indicator-grid,
    .evidence-grid { grid-template-columns: 1fr; }
    .mechanism-flow article { min-height: 0; }
    .mechanism-flow article > div i { transform: rotate(90deg); }
    .company-list { grid-template-columns: repeat(2, 1fr); }
    .theme-workbench > summary { align-items: flex-start; flex-direction: column; }
    .subsection-head { align-items: flex-start; flex-direction: column; gap: 0.35rem; }
  }

  @media (max-width: 420px) {
    .company-list { grid-template-columns: 1fr; }
  }
</style>
