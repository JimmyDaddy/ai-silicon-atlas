---
import BaseLayout from "../layouts/BaseLayout.astro";
import { companies } from "../data/companies";
import { dataSnapshot, formatDate, getCompanyUpdate } from "../data/updates";
import { sitePath } from "../lib/paths";

interface SourceStatus {
  status: string;
  provider: string;
  completedAt?: string;
  companyCount?: number;
  url?: string;
  error?: string;
}

const sources = Object.values(dataSnapshot.sources as Record<string, SourceStatus>);
const companyUpdates = companies.map((company) => ({ company, update: getCompanyUpdate(company.slug) }));
const recentFilings = companyUpdates
  .filter((item) => item.update?.latestFiling)
  .sort((left, right) => (right.update?.latestFiling?.filedAt ?? "").localeCompare(left.update?.latestFiling?.filedAt ?? ""))
  .slice(0, 12);
const statusCounts = companyUpdates.reduce<Record<string, number>>((counts, item) => {
  const status = item.update?.status ?? "pending";
  counts[status] = (counts[status] ?? 0) + 1;
  return counts;
}, {});
---

<BaseLayout title="数据更新 · 智芯图谱" description="查看智芯图谱定时数据更新状态、官方数据源和最新公司披露。" active="updates">
  <section class="page-hero updates-hero">
    <div class="shell page-hero-grid">
      <div>
        <span class="eyebrow">Data pipeline</span>
        <h1 class="display-title">数据如何<br /><em>保持更新</em></h1>
      </div>
      <div>
        <p class="page-kicker">GitHub Actions 每天拉取官方披露，完成标识归一、指标抽取、数据校验和静态站点重建。</p>
        <div class="page-meta">
          <span><i></i>最新快照 {formatDate(dataSnapshot.generatedAt)}</span>
          <span>Schema v{dataSnapshot.schemaVersion}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="status-section section-rule">
    <div class="shell">
      <div class="status-summary">
        <div><strong>{statusCounts.ok ?? 0}</strong><span>自动同步</span></div>
        <div><strong>{statusCounts.manual ?? 0}</strong><span>人工维护</span></div>
        <div><strong>{statusCounts.unconfigured ?? 0}</strong><span>等待配置</span></div>
        <div><strong>{statusCounts.error ?? 0}</strong><span>本次异常</span></div>
      </div>
      <div class="source-grid">
        {sources.map((source) => (
          <article class={`source-status status-${source.status}`}>
            <div class="source-head"><i></i><span>{source.status.toUpperCase()}</span></div>
            <h2>{source.provider}</h2>
            <p>{source.companyCount ?? 0} 家公司 · 完成于 {formatDate(source.completedAt)}</p>
            {source.url ? <a href={source.url} target="_blank" rel="noreferrer">打开数据源 ↗</a> : <span class="manual-tag">仓库内维护</span>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell update-grid">
      <div>
        <div class="section-head">
          <div>
            <span class="eyebrow">Latest filings</span>
            <h2 class="section-title">最近官方披露</h2>
          </div>
        </div>
        <div class="filing-list">
          {recentFilings.length > 0 ? recentFilings.map(({ company, update }, index) => (
            <a href={update!.latestFiling!.url} target="_blank" rel="noreferrer" class="filing-row">
              <span class="filing-index">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <strong>{company.name}</strong>
                <p>{update!.latestFiling!.title}</p>
              </div>
              <div class="filing-meta"><span>{update!.latestFiling!.form}</span><small>{update!.latestFiling!.filedAt}</small></div>
              <i>↗</i>
            </a>
          )) : <div class="pending-box">首次运行 <code>npm run data:update</code> 后，这里会显示最新官方披露。</div>}
        </div>
      </div>

      <aside>
        <span class="eyebrow">Pipeline</span>
        <h2>更新链路</h2>
        <ol>
          <li><span>01</span><div><strong>Fetch</strong><small>请求官方 API 与披露</small></div></li>
          <li><span>02</span><div><strong>Normalize</strong><small>统一公司标识和字段</small></div></li>
          <li><span>03</span><div><strong>Validate</strong><small>检查时间、指标和链接</small></div></li>
          <li><span>04</span><div><strong>Commit</strong><small>只提交发生变化的快照</small></div></li>
          <li><span>05</span><div><strong>Deploy</strong><small>重新构建 GitHub Pages</small></div></li>
        </ol>
        <div class="note-box"><strong>失败保护：</strong>远端接口临时失败时保留上一次成功快照并标记为过期，避免线上数据被清空。</div>
        <a class="button" href={sitePath("/methodology/")}>查看数据方法 <span class="arrow">→</span></a>
      </aside>
    </div>
  </section>

  <section class="section section-rule registry-section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Coverage registry</span>
          <h2 class="section-title">公司更新状态</h2>
        </div>
      </div>
      <div class="registry-table">
        <div class="registry-row registry-head"><span>公司</span><span>市场</span><span>方式</span><span>最后检查</span></div>
        {companyUpdates.map(({ company, update }) => (
          <a class="registry-row" href={sitePath(`/companies/${company.slug}/`)}>
            <span><strong>{company.name}</strong><small>{company.ticker}</small></span>
            <span>{company.exchange}</span>
            <span class={`registry-status status-${update?.status ?? "pending"}`}><i></i>{update?.provider ?? "待生成"}</span>
            <span>{formatDate(update?.checkedAt)}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .updates-hero {
    background: radial-gradient(circle at 78% 58%, rgba(99, 230, 190, 0.08), transparent 24rem);
  }

  .status-section {
    padding: 2.5rem 0 4rem;
  }

  .status-summary {
    border: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-bottom: 1rem;
  }

  .status-summary div {
    border-right: 1px solid var(--line);
    display: grid;
    gap: 0.25rem;
    padding: 1.2rem;
  }

  .status-summary div:last-child { border-right: 0; }
  .status-summary strong { font-family: var(--font-display); font-size: 1.8rem; font-weight: 500; }
  .status-summary span { color: var(--text-dim); font-size: 0.62rem; }

  .source-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(3, 1fr);
  }

  .source-status {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    display: grid;
    min-height: 12rem;
    padding: 1.1rem;
  }

  .source-head { align-items: center; color: var(--text-dim); display: flex; font-family: var(--font-mono); font-size: 0.52rem; gap: 0.45rem; }
  .source-head i { background: var(--mint); border-radius: 50%; height: 0.35rem; width: 0.35rem; }
  .status-unconfigured .source-head i,
  .status-manual .source-head i { background: var(--amber); }
  .status-error .source-head i { background: var(--rose); }
  .source-status h2 { align-self: end; font-family: var(--font-display); font-size: 1.4rem; font-weight: 500; margin: 1.5rem 0 0.35rem; }
  .source-status p { color: var(--text-dim); font-size: 0.62rem; margin: 0; }
  .source-status a,
  .manual-tag { align-self: end; color: var(--text-muted); font-size: 0.65rem; margin-top: 1rem; text-decoration: none; }

  .update-grid {
    display: grid;
    gap: 5rem;
    grid-template-columns: minmax(0, 1fr) 19rem;
  }

  .filing-list { border-top: 1px solid var(--line); }
  .filing-row { align-items: center; border-bottom: 1px solid var(--line); color: var(--text-muted); display: grid; gap: 1rem; grid-template-columns: 2rem 1fr auto 1rem; padding: 1rem 0; text-decoration: none; }
  .filing-row:hover { color: var(--text-strong); }
  .filing-index { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.55rem; }
  .filing-row strong { color: var(--text-strong); font-size: 0.78rem; }
  .filing-row p { color: var(--text-dim); font-size: 0.68rem; margin: 0.25rem 0 0; }
  .filing-meta { display: grid; gap: 0.25rem; justify-items: end; }
  .filing-meta span { color: var(--mint); font-family: var(--font-mono); font-size: 0.62rem; }
  .filing-meta small { color: var(--text-dim); font-size: 0.58rem; }
  .filing-row > i { color: var(--mint); font-style: normal; }
  .pending-box { border: 1px dashed var(--line-strong); color: var(--text-muted); font-size: 0.75rem; padding: 2rem; }

  aside { position: sticky; top: 6rem; }
  aside > h2 { font-family: var(--font-display); font-size: 1.8rem; font-weight: 500; margin: 0.7rem 0 1.5rem; }
  aside ol { border-top: 1px solid var(--line); list-style: none; margin: 0 0 1.5rem; padding: 0; }
  aside li { align-items: center; border-bottom: 1px solid var(--line); display: grid; gap: 0.8rem; grid-template-columns: 2rem 1fr; padding: 0.75rem 0; }
  aside li > span { color: var(--mint); font-family: var(--font-mono); font-size: 0.55rem; }
  aside li div { display: grid; gap: 0.2rem; }
  aside li strong { font-size: 0.72rem; }
  aside li small { color: var(--text-dim); font-size: 0.6rem; }
  aside .button { margin-top: 1rem; }

  .registry-table { border-top: 1px solid var(--line); }
  .registry-row { align-items: center; border-bottom: 1px solid var(--line); color: var(--text-muted); display: grid; font-size: 0.7rem; gap: 1rem; grid-template-columns: 1.2fr 0.5fr 1fr 0.6fr; padding: 0.85rem; text-decoration: none; }
  .registry-row:not(.registry-head):hover { background: var(--surface-soft); color: var(--text-strong); }
  .registry-head { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.52rem; letter-spacing: 0.08em; }
  .registry-row > span:first-child { display: grid; gap: 0.2rem; }
  .registry-row small { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.52rem; }
  .registry-status { align-items: center; display: flex; gap: 0.45rem; }
  .registry-status i { background: var(--mint); border-radius: 50%; height: 0.35rem; width: 0.35rem; }
  .registry-status.status-manual i,
  .registry-status.status-unconfigured i { background: var(--amber); }
  .registry-status.status-error i { background: var(--rose); }

  @media (max-width: 820px) {
    .update-grid { grid-template-columns: 1fr; }
    aside { position: static; }
  }

  @media (max-width: 600px) {
    .status-summary { grid-template-columns: repeat(2, 1fr); }
    .status-summary div:nth-child(2) { border-right: 0; }
    .source-grid { grid-template-columns: 1fr; }
    .filing-row { grid-template-columns: 1.5rem 1fr 1rem; }
    .filing-meta { display: none; }
    .registry-row { grid-template-columns: 1fr 0.7fr; }
    .registry-row > span:nth-child(2),
    .registry-row > span:nth-child(4) { display: none; }
  }
</style>
