---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CompanyCard from "../../components/CompanyCard.astro";
import MetricTrend from "../../components/MetricTrend.astro";
import { analysisStatusLabel, getCompanyAnalysis } from "../../data/analysis";
import { companies, type Company } from "../../data/companies";
import { getCompanyProfile } from "../../data/company-profiles";
import { stageByKey } from "../../data/stages";
import { formatDate, getCompanyUpdate, type MetricSnapshot } from "../../data/updates";
import { sitePath } from "../../lib/paths";

export function getStaticPaths() {
  return companies.map((company) => ({ params: { slug: company.slug }, props: { company } }));
}

const { company } = Astro.props as { company: Company };
const stage = stageByKey[company.stage];
const profile = getCompanyProfile(company.slug);
const update = getCompanyUpdate(company.slug);
const analysis = getCompanyAnalysis(company.slug);
const metrics = Object.entries(update?.metrics ?? {}) as [string, MetricSnapshot][];
const metricHistory = update?.metricHistory ?? {};
const recentFilings = (update?.recentFilings ?? []).slice(0, 6);
const relatedCompanies = companies
  .filter((candidate) => candidate.stage === company.stage && candidate.slug !== company.slug)
  .slice(0, 3);
const metricLabels: Record<string, string> = {
  revenue: "最新披露收入",
  netIncome: "最新披露净利润",
  assets: "总资产",
  cash: "现金及等价物",
  capex: "资本开支",
};
const statusCopy = {
  ok: "官方数据已同步",
  manual: "第一方资料人工维护",
  unconfigured: "官方接口待配置",
  error: "本次同步异常",
};
const analysisSections = analysis?.status === "ok" ? [
  { key: "whatChanged", label: "发生了什么变化", points: analysis.whatChanged ?? [] },
  { key: "operatingSignals", label: "经营与财务信号", points: analysis.operatingSignals ?? [] },
  { key: "valueChainImpact", label: "价值链影响", points: analysis.valueChainImpact ?? [] },
  { key: "uncertainties", label: "不确定性与边界", points: analysis.uncertainties ?? [] },
] : [];
const evidenceById = Object.fromEntries((analysis?.evidenceSources ?? []).map((source) => [source.id, source]));
const analysisFallback = (() => {
  if (analysis?.status === "error") {
    return {
      eyebrow: "AI LAYER / RETRY",
      title: "本次分析失败，等待自动重试",
      description: "数据更新任务会保留已有结果，并在下一批次重新尝试生成；失败不会被包装成分析结论。",
    };
  }
  if (analysis?.status === "unavailable" && update?.status === "unconfigured") {
    return {
      eyebrow: "AI LAYER / SOURCE CONFIG",
      title: "需要先配置官方数据接口",
      description: `${company.name} 当前的官方结构化数据源尚未启用。完成 OpenDART 等接口配置后，才会进入 AI 证据分析队列。`,
    };
  }
  if (analysis?.status === "unavailable") {
    return {
      eyebrow: "AI LAYER / SOURCE COVERAGE",
      title: "尚未接入结构化数据源",
      description: `${company.name} 目前以第一方资料入口人工维护。由于证据包还不完整，系统不会生成看似确定的 AI 分析。`,
    };
  }
  return {
    eyebrow: "AI LAYER / QUEUED",
    title: "等待下一批 AI 分析",
    description: "结构化证据已经准备完成，将按最新披露日期进入后续分析批次。",
  };
})();
---

<BaseLayout title={`${company.name}（${company.ticker}）· 智芯图谱`} description={`${company.name}所属${stage.name}环节的公司研究卡、关注变量与第一方资料。`} active="companies">
  <section class="company-hero" style={`--company-accent: ${stage.accent}`}>
    <div class="shell">
      <nav class="breadcrumbs" aria-label="面包屑">
        <a href={sitePath("/companies/")}>公司目录</a><span>/</span><a href={sitePath(`/map/#${stage.key}`)}>{stage.name}</a><span>/</span><strong>{company.ticker}</strong>
      </nav>
      <div class="company-heading">
        <div>
          <div class="company-label"><i></i>{stage.nameEn} · {company.country}</div>
          <h1>{company.name}</h1>
          <p>{company.nameEn}</p>
        </div>
        <div class="security-card">
          <span>LISTED SECURITY</span>
          <strong>{company.ticker}</strong>
          <small>{company.exchange}</small>
        </div>
      </div>
      <p class="company-lead">{company.description}</p>
      <div class="focus-tags">
        {company.focus.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </section>

  <section class="snapshot-bar section-rule">
    <div class="shell snapshot-inner">
      <div>
        <small>DATA STATUS</small>
        <strong class:list={[{ warning: update?.status !== "ok" }]}><i></i>{update ? statusCopy[update.status] : "数据快照尚未生成"}</strong>
      </div>
      <div>
        <small>PROVIDER</small>
        <strong>{update?.provider ?? "—"}</strong>
      </div>
      <div>
        <small>LAST CHECK</small>
        <strong>{formatDate(update?.checkedAt)}</strong>
      </div>
      <a href={sitePath("/updates/")}>查看更新状态 ↗</a>
    </div>
  </section>

  <section class="section company-content" style={`--company-accent: ${stage.accent}`}>
    <div class="shell">
      {metrics.length > 0 && (
        <div class="metrics-section">
          <div class="section-head compact-head">
            <div>
              <span class="eyebrow">Official snapshot</span>
              <h2 class="section-title">最新官方披露快照</h2>
              <p class="section-copy">不同指标可能来自不同报告期，请以指标下方的日期和原始披露为准。</p>
            </div>
          </div>
          <div class="metrics-grid">
            {metrics.map(([key, metric]) => (
              <MetricTrend
                label={metricLabels[key] ?? metric.label ?? key}
                metric={metric}
                history={metricHistory[key]}
                accent={stage.accent}
              />
            ))}
          </div>
        </div>
      )}

      <section class:list={["ai-analysis", { ready: analysis?.status === "ok" }]} style={`--analysis-accent: ${stage.accent}`}>
        <div class="ai-analysis-head">
          <div>
            <span class="eyebrow">Evidence-grounded synthesis</span>
            <h2 class="section-title">AI 综合分析</h2>
            <p class="section-copy">仅基于结构化官方披露和历史指标，区分事实证据、产业影响与不确定性，不生成买卖建议。</p>
          </div>
          <div class="analysis-status">
            <span class={`status-${analysis?.status ?? "pending"}`}><i></i>{analysis ? analysisStatusLabel(analysis.status) : "等待分析数据"}</span>
            {analysis?.status === "ok" && <small>{analysis.model} · {analysis.confidence?.toUpperCase()} CONFIDENCE</small>}
          </div>
        </div>

        {analysis?.status === "ok" ? (
          <div class="analysis-body">
            <div class="analysis-summary">
              <span>EXECUTIVE SYNTHESIS</span>
              <p>{analysis.summary}</p>
              <small>生成于 {formatDate(analysis.generatedAt)} · Prompt {analysis.promptVersion}</small>
            </div>
            <div class="analysis-grid">
              {analysisSections.map((section, index) => (
                <article>
                  <div><span>{String(index + 1).padStart(2, "0")}</span><small>{section.key.toUpperCase()}</small></div>
                  <h3>{section.label}</h3>
                  <ul>
                    {section.points.map((point) => (
                      <li>
                        <p>{point.text}</p>
                        {point.evidence.length > 0 && <div>{point.evidence.map((id) => evidenceById[id] ? <a href={evidenceById[id].url} target="_blank" rel="noreferrer">{evidenceById[id].label} ↗</a> : null)}</div>}
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
            {(analysis.questionsToWatch?.length ?? 0) > 0 && (
              <div class="analysis-questions">
                <span>NEXT QUESTIONS</span>
                <div>{analysis.questionsToWatch!.map((question, index) => <p><i>{String(index + 1).padStart(2, "0")}</i>{question}</p>)}</div>
              </div>
            )}
          </div>
        ) : (
          <div class="analysis-pending">
            <span>{analysisFallback.eyebrow}</span>
            <h3>{analysisFallback.title}</h3>
            <p>{analysisFallback.description}</p>
          </div>
        )}
      </section>

      <section class="profile-section">
        <div class="section-head compact-head">
          <div>
            <span class="eyebrow">Company research profile</span>
            <h2 class="section-title">公司研究档案</h2>
            <p class="section-copy">把公司放回商业模式、竞争位置和上下游依赖中理解。</p>
          </div>
        </div>
        <div class="profile-lead">
          <span>BUSINESS MODEL</span>
          <p>{profile.businessModel}</p>
        </div>
        <div class="profile-grid">
          <article><span>核心能力</span><ul>{profile.moat.map((item) => <li>{item}</li>)}</ul></article>
          <article><span>主要终端市场</span><ul>{profile.endMarkets.map((item) => <li>{item}</li>)}</ul></article>
          <article><span>竞争参照</span><ul>{profile.competitors.map((item) => <li>{item}</li>)}</ul></article>
          <article><span>关键依赖</span><ul>{profile.dependencies.map((item) => <li>{item}</li>)}</ul></article>
        </div>
        <div class="profile-questions">
          <span>QUESTIONS TO VERIFY</span>
          <div>{profile.questions.map((question, index) => <p><i>{String(index + 1).padStart(2, "0")}</i>{question}</p>)}</div>
        </div>
      </section>

      <div class="research-grid">
        <div class="research-main">
          <section class="research-block attention-block">
            <div class="block-label"><span>01</span><small>WHAT TO WATCH</small></div>
            <h2>研究关注点</h2>
            <ul>
              {company.attention.map((item) => <li><i></i><span>{item}</span></li>)}
            </ul>
          </section>
          <section class="research-block risk-block">
            <div class="block-label"><span>02</span><small>RISK BOUNDARIES</small></div>
            <h2>风险与反证</h2>
            <ul>
              {company.risks.map((item) => <li><i></i><span>{item}</span></li>)}
            </ul>
          </section>
        </div>

        <aside>
          {update?.latestFiling && (
            <section class="filing-card">
              <span class="card-kicker">LATEST OFFICIAL FILING</span>
              <div class="filing-form">{update.latestFiling.form}</div>
              <h2>{update.latestFiling.title}</h2>
              <p>披露日期 {update.latestFiling.filedAt}</p>
              <a href={update.latestFiling.url} target="_blank" rel="noreferrer">打开官方原文 <span>↗</span></a>
            </section>
          )}
          <section class="source-card">
            <span class="card-kicker">PRIMARY SOURCES</span>
            <h2>第一方资料</h2>
            <div class="source-links">
              {company.sources.map((source) => (
                <a href={source.url} target="_blank" rel="noreferrer">
                  <span>{source.label}</span><i>↗</i>
                </a>
              ))}
            </div>
            <p>本站只整理研究入口与结构化快照，结论应回到原始披露独立核验。</p>
          </section>
        </aside>
      </div>

      {recentFilings.length > 1 && (
        <section class="filing-timeline">
          <div class="section-head compact-head">
            <div>
              <span class="eyebrow">Disclosure timeline</span>
              <h2 class="section-title">最近官方披露</h2>
            </div>
          </div>
          <div class="timeline-list">
            {recentFilings.map((filing, index) => (
              <a href={filing.url} target="_blank" rel="noreferrer">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <div><strong>{filing.title}</strong><small>{filing.accessionNumber}</small></div>
                <div><b>{filing.form}</b><small>{filing.filedAt}</small></div>
                <i>↗</i>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>

  {relatedCompanies.length > 0 && (
    <section class="section section-rule related-section">
      <div class="shell">
        <div class="section-head">
          <div>
            <span class="eyebrow">Same layer</span>
            <h2 class="section-title">同环节公司</h2>
          </div>
          <a class="text-link" href={sitePath(`/map/#${stage.key}`)}>返回{stage.name}地图 <span>→</span></a>
        </div>
        <div class="related-grid">
          {relatedCompanies.map((related) => <CompanyCard company={related} compact />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .company-hero {
    background: radial-gradient(circle at 75% 35%, color-mix(in srgb, var(--company-accent) 10%, transparent), transparent 28rem);
    padding: 3rem 0 4rem;
  }

  .breadcrumbs {
    align-items: center;
    color: var(--text-dim);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    gap: 0.6rem;
    margin-bottom: 4rem;
  }

  .breadcrumbs a {
    color: var(--text-dim);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: var(--company-accent);
  }

  .breadcrumbs strong {
    color: var(--text-muted);
    font-weight: 400;
  }

  .company-heading {
    align-items: end;
    display: flex;
    gap: 3rem;
    justify-content: space-between;
  }

  .company-label {
    align-items: center;
    color: var(--company-accent);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    gap: 0.55rem;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .company-label i {
    background: var(--company-accent);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--company-accent);
    height: 0.38rem;
    width: 0.38rem;
  }

  .company-heading h1 {
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 8vw, 7rem);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin: 0;
  }

  .company-heading p {
    color: var(--text-muted);
    font-size: 0.82rem;
    margin: 0.8rem 0 0;
  }

  .security-card {
    border: 1px solid var(--line-strong);
    display: grid;
    min-width: 10rem;
    padding: 1rem;
  }

  .security-card span,
  .security-card small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
  }

  .security-card strong {
    color: var(--company-accent);
    font-family: var(--font-mono);
    font-size: 1.4rem;
    margin: 1.2rem 0 0.2rem;
  }

  .company-lead {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.85;
    margin: 2.3rem 0 1.3rem;
    max-width: 42rem;
  }

  .focus-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .focus-tags span {
    background: color-mix(in srgb, var(--company-accent) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--company-accent) 24%, transparent);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.64rem;
    padding: 0.4rem 0.65rem;
  }

  .snapshot-bar {
    background: rgba(5, 11, 20, 0.42);
    padding: 1.25rem 0;
  }

  .snapshot-inner {
    align-items: center;
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(3, 1fr) auto;
  }

  .snapshot-inner > div {
    display: grid;
    gap: 0.45rem;
  }

  .snapshot-inner small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.1em;
  }

  .snapshot-inner strong {
    align-items: center;
    color: var(--text-muted);
    display: flex;
    font-size: 0.7rem;
    font-weight: 500;
    gap: 0.45rem;
  }

  .snapshot-inner strong i {
    background: var(--mint);
    border-radius: 50%;
    height: 0.35rem;
    width: 0.35rem;
  }

  .snapshot-inner strong.warning i {
    background: var(--amber);
  }

  .snapshot-inner > a {
    color: var(--text-muted);
    font-size: 0.68rem;
    text-decoration: none;
  }

  .metrics-section {
    border-bottom: 1px solid var(--line);
    margin-bottom: 4rem;
    padding-bottom: 4rem;
  }

  .compact-head {
    margin-bottom: 1.8rem;
  }

  .compact-head .section-title {
    font-size: 2.4rem;
  }

  .metrics-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(5, 1fr);
  }

  .metrics-grid article {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    display: grid;
    min-height: 8.5rem;
    padding: 1rem;
  }

  .metrics-grid span,
  .metrics-grid small {
    color: var(--text-dim);
    font-size: 0.58rem;
  }

  .metrics-grid strong {
    align-self: center;
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 500;
  }

  .ai-analysis {
    background: linear-gradient(135deg, rgba(99, 230, 190, 0.04), rgba(167, 139, 250, 0.035));
    border: 1px solid var(--line-strong);
    margin-bottom: 4rem;
    overflow: hidden;
    padding: 1.5rem;
    position: relative;
  }

  .ai-analysis::before {
    background: linear-gradient(90deg, var(--analysis-accent), transparent);
    content: "";
    height: 1px;
    left: 1.5rem;
    position: absolute;
    right: 65%;
    top: 0;
  }

  .ai-analysis-head {
    align-items: start;
    display: flex;
    gap: 2rem;
    justify-content: space-between;
  }

  .ai-analysis-head .section-title {
    font-size: 2.5rem;
    margin-top: 0.55rem;
  }

  .analysis-status {
    align-items: flex-end;
    display: grid;
    gap: 0.45rem;
    justify-items: end;
  }

  .analysis-status > span {
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-muted);
    display: flex;
    font-size: 0.62rem;
    gap: 0.45rem;
    padding: 0.4rem 0.6rem;
  }

  .analysis-status i {
    background: var(--amber);
    border-radius: 50%;
    height: 0.35rem;
    width: 0.35rem;
  }

  .analysis-status .status-ok i {
    background: var(--mint);
    box-shadow: 0 0 10px rgba(99, 230, 190, 0.7);
  }

  .analysis-status .status-error i { background: var(--rose); }

  .analysis-status small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.48rem;
  }

  .analysis-body {
    margin-top: 2rem;
  }

  .analysis-summary {
    border-left: 1px solid var(--analysis-accent);
    max-width: 56rem;
    padding: 0.2rem 0 0.2rem 1.1rem;
  }

  .analysis-summary > span,
  .analysis-questions > span,
  .profile-lead > span,
  .profile-questions > span {
    color: var(--analysis-accent, var(--company-accent));
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
  }

  .analysis-summary p {
    color: var(--text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.55;
    margin: 0.7rem 0;
  }

  .analysis-summary small {
    color: var(--text-dim);
    font-size: 0.55rem;
  }

  .analysis-grid {
    border-left: 1px solid var(--line);
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    margin-top: 2rem;
  }

  .analysis-grid > article {
    border-bottom: 1px solid var(--line);
    border-right: 1px solid var(--line);
    min-height: 17rem;
    padding: 1.1rem;
  }

  .analysis-grid article > div:first-child {
    align-items: center;
    display: flex;
    justify-content: space-between;
  }

  .analysis-grid article > div:first-child span {
    color: var(--analysis-accent);
    font-family: var(--font-mono);
    font-size: 0.55rem;
  }

  .analysis-grid article > div:first-child small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.46rem;
  }

  .analysis-grid h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    margin: 2rem 0 1rem;
  }

  .analysis-grid ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .analysis-grid li {
    border-top: 1px solid var(--line);
    padding: 0.75rem 0;
  }

  .analysis-grid li p {
    color: var(--text-muted);
    font-size: 0.7rem;
    line-height: 1.65;
    margin: 0;
  }

  .analysis-grid li > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .analysis-grid li a {
    color: var(--analysis-accent);
    font-size: 0.5rem;
    text-decoration: none;
  }

  .analysis-questions,
  .profile-questions {
    border-top: 1px solid var(--line);
    margin-top: 1.5rem;
    padding-top: 1rem;
  }

  .analysis-questions > div,
  .profile-questions > div {
    display: grid;
    gap: 0.6rem;
    grid-template-columns: repeat(2, 1fr);
    margin-top: 0.8rem;
  }

  .analysis-questions p,
  .profile-questions p {
    align-items: start;
    color: var(--text-muted);
    display: grid;
    font-size: 0.68rem;
    gap: 0.55rem;
    grid-template-columns: 1.5rem 1fr;
    line-height: 1.55;
    margin: 0;
  }

  .analysis-questions p i,
  .profile-questions p i {
    color: var(--analysis-accent, var(--company-accent));
    font-family: var(--font-mono);
    font-size: 0.5rem;
    font-style: normal;
  }

  .analysis-pending {
    border: 1px dashed var(--line-strong);
    margin-top: 2rem;
    padding: 2rem;
  }

  .analysis-pending > span {
    color: var(--amber);
