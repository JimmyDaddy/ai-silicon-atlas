---
import Logo from "./Logo.astro";
import { sitePath } from "../lib/paths";

interface Props {
  active?: "home" | "map" | "companies" | "news" | "research" | "updates" | "methodology";
}

const { active } = Astro.props;
const navItems = [
  { key: "map", label: "产业地图", href: "/map/" },
  { key: "companies", label: "公司目录", href: "/companies/" },
  { key: "news", label: "权威情报", href: "/news/" },
  { key: "research", label: "研究主题", href: "/research/" },
  { key: "updates", label: "数据更新", href: "/updates/" },
  { key: "methodology", label: "方法与来源", href: "/methodology/" },
] as const;
---

<header class="site-header" data-header>
  <div class="shell header-inner">
    <Logo />
    <button class="nav-toggle" type="button" aria-label="打开导航" aria-expanded="false" data-nav-toggle>
      <span></span><span></span>
    </button>
    <nav class="main-nav" aria-label="主导航" data-nav>
      {navItems.map((item) => (
        <a class:list={[{ active: active === item.key }]} href={sitePath(item.href)}>
          {item.label}
        </a>
      ))}
    </nav>
    <a class="header-cta" href={sitePath("/companies/")}>开始探索 <span aria-hidden="true">↗</span></a>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>("[data-header]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const nav = document.querySelector<HTMLElement>("[data-nav]");

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    toggle.setAttribute("aria-label", isOpen ? "打开导航" : "关闭导航");
    nav?.classList.toggle("open", !isOpen);
  });

  const updateHeader = () => header?.classList.toggle("scrolled", window.scrollY > 10);
  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });
</script>

<style>
  .site-header {
    backdrop-filter: blur(16px);
    background: rgba(6, 14, 25, 0.76);
    border-bottom: 1px solid transparent;
    left: 0;
    position: sticky;
    right: 0;
    top: 0;
    transition: border-color 180ms ease, background 180ms ease;
    z-index: 50;
  }

  .site-header.scrolled {
    background: rgba(6, 14, 25, 0.92);
    border-color: var(--line);
  }

  .header-inner {
    align-items: center;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: auto 1fr auto;
    min-height: 4.8rem;
  }

  .main-nav {
    align-items: center;
    display: flex;
    gap: 0.25rem;
    justify-content: center;
  }

  .main-nav a {
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    padding: 0.65rem 0.85rem;
    text-decoration: none;
    transition: color 150ms ease, background 150ms ease;
  }

  .main-nav a:hover,
  .main-nav a.active {
    background: rgba(255, 255, 255, 0.055);
    color: var(--text-strong);
  }

  .header-cta {
    align-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--text-strong);
    display: inline-flex;
    font-size: 0.78rem;
    gap: 0.45rem;
    padding: 0.65rem 0.9rem;
    text-decoration: none;
  }

  .header-cta span {
    color: var(--mint);
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 2.5rem;
    padding: 0.6rem;
    width: 2.5rem;
  }

  .nav-toggle span {
    background: var(--text-strong);
    display: block;
    height: 1px;
    margin: 0.36rem 0;
    transition: transform 160ms ease;
    width: 100%;
  }

  @media (max-width: 820px) {
    .header-inner {
      grid-template-columns: 1fr auto;
    }

    .nav-toggle {
      display: block;
    }

    .main-nav {
      align-items: stretch;
      background: var(--surface-raised);
      border: 1px solid var(--line);
      border-radius: 1rem;
      display: none;
      flex-direction: column;
      grid-column: 1 / -1;
      justify-content: flex-start;
      padding: 0.65rem;
      position: absolute;
      right: 1rem;
      top: 4.2rem;
      width: min(18rem, calc(100vw - 2rem));
    }

    .main-nav.open {
      display: flex;
    }

    .main-nav a {
      border-radius: 0.65rem;
      padding: 0.8rem;
    }

    .header-cta {
      display: none;
    }
  }
</style>
