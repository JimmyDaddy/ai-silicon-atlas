---
import BaseLayout from "../layouts/BaseLayout.astro";
import CompanyCard from "../components/CompanyCard.astro";
import NewsCard from "../components/NewsCard.astro";
import StageCard from "../components/StageCard.astro";
import { companies, markets } from "../data/companies";
import { newsArticles } from "../data/news";
import { stages } from "../data/stages";
import { themes } from "../data/themes";
import { sitePath } from "../lib/paths";

const homepageFeaturedSlugs = ["nvidia", "tsmc", "arista-networks", "microsoft", "palantir", "sk-hynix"];
const homepageFeatured = homepageFeaturedSlugs
  .map((slug) => companies.find((company) => company.slug === slug))
  .filter((company) => company !== undefined);
const homepageNewsIds = ["bis-bulletin-128", "blackstone-2026-mid-year"];
const homepageNews = [
  ...homepageNewsIds.map((id) => newsArticles.find((article) => article.id === id)),
  newsArticles.find((article) => !homepageNewsIds.includes(article.id)),
].filter((article) => article !== undefined);
---

<BaseLayout active="home">
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="shell hero-grid">
      <div class="hero-content reveal">
        <div class="hero-overline">
          <span class="status-pulse"></span>
          AI × SEMICONDUCTOR VALUE CHAIN · V0.1
        </div>
        <h1><span>看清 AI 背后的</span><br /><em>价值流向</em></h1>
        <p class="hero-copy">
          从芯片、数据中心到模型平台与 AI 应用，沿完整价值链整理全球代表公司与研究线索。
        </p>
        <div class="button-row hero-actions">
          <a class="button primary" href={sitePath("/map/")}>进入产业地图 <span class="arrow">↗</span></a>
          <a class="button" href={sitePath("/companies/")}>浏览公司目录 <span class="arrow">→</span></a>
        </div>
        <p class="hero-note">静态研究索引 · 来源可追溯 · 非实时行情</p>
      </div>

      <div class="signal-panel reveal delay-2" aria-label="AI 与半导体价值链示意图">
        <div class="panel-head">
          <span>VALUE CHAIN / 01—09</span>
          <span class="panel-live"><i></i> STATIC INDEX</span>
        </div>
        <div class="chip-diagram" aria-hidden="true">
          <div class="orbit orbit-a"></div>
          <div class="orbit orbit-b"></div>
          <div class="chip-core">
            <span>Si</span>
            <small>AI ATLAS</small>
          </div>
          {stages.map((stage, index) => (
            <div class={`diagram-node node-${index + 1}`} style={`--node-color: ${stage.accent}`}>
              <i></i>
              <span>{stage.index}</span>
              <strong>{stage.name}</strong>
            </div>
          ))}
        </div>
        <div class="panel-foot">
          <span>DESIGN</span><i></i><span>COMPUTE</span><i></i><span>APPLY</span>
        </div>
      </div>
    </div>
    <div class="shell hero-stats reveal delay-3">
      <div><strong>{companies.length}</strong><span>代表公司</span></div>
      <div><strong>{stages.length}</strong><span>产业环节</span></div>
      <div><strong>{markets.length}</strong><span>主要市场</span></div>
      <div><strong>2026.07</strong><span>资料版本</span></div>
    </div>
  </section>

  <section class="section chain-section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Industry chain</span>
          <h2 class="section-title">从硅片到 AI 应用</h2>
          <p class="section-copy">AI 的价值链横跨硬件、基础设施、模型和应用，每个环节的商业模式与跟踪变量都不同。</p>
        </div>
        <a class="text-link" href={sitePath("/map/")}>查看完整产业地图 <span>→</span></a>
      </div>
      <div class="stage-grid">
        {stages.map((stage) => <StageCard stage={stage} />)}
      </div>
    </div>
  </section>

  <section class="section section-rule themes-section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Research lenses</span>
          <h2 class="section-title">用问题组织信息</h2>
          <p class="section-copy">不追逐每一条新闻，而是持续追踪能改变供需、价值量和竞争位置的变量。</p>
        </div>
        <a class="text-link" href={sitePath("/research/")}>全部研究主题 <span>→</span></a>
      </div>
      <div class="theme-grid">
        {themes.map((theme, index) => (
          <article class={`theme-card ${theme.tone}`}>
            <div class="theme-number">0{index + 1}</div>
            <span class="theme-eyebrow">{theme.eyebrow}</span>
            <h3>{theme.title}</h3>
            <p>{theme.summary}</p>
            <blockquote>{theme.question}</blockquote>
            <div class="theme-signals">
              {theme.signals.map((signal) => <span>{signal}</span>)}
            </div>
            <a href={sitePath(`/research/#${theme.slug}`)}>展开研究框架 <span aria-hidden="true">↗</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-rule intelligence-preview">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Authority intelligence</span>
          <h2 class="section-title">从权威文章中提炼产业信号</h2>
          <p class="section-copy">聚合国际机构、央行研究与公司一手观点，用 AI 归纳价值链影响，同时保留来源立场和原文入口。</p>
        </div>
        <a class="text-link" href={sitePath("/news/")}>进入综合情报流 <span>→</span></a>
      </div>
      <div class="news-preview-grid">
        {homepageNews.map((article) => <NewsCard article={article} compact />)}
      </div>
    </div>
  </section>

  <section class="section section-rule">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Company index</span>
          <h2 class="section-title">代表公司研究卡</h2>
          <p class="section-copy">每张研究卡都标记所属环节、关注变量、风险项与第一方资料入口。</p>
        </div>
        <a class="text-link" href={sitePath("/companies/")}>浏览 {companies.length} 家公司 <span>→</span></a>
      </div>
      <div class="featured-grid">
        {homepageFeatured.map((company) => <CompanyCard company={company} compact />)}
      </div>
    </div>
  </section>

  <section class="section section-rule method-preview">
    <div class="shell method-grid">
      <div>
        <span class="eyebrow">Source first</span>
        <h2 class="section-title">信息有出处，判断有边界</h2>
      </div>
      <div class="method-copy">
        <p>网站优先连接公司公告、投资者关系页面和交易所披露。事实、研究线索和风险提示分开呈现。</p>
        <ol>
          <li><span>01</span><strong>定位环节</strong><small>先确认公司靠什么创造价值</small></li>
          <li><span>02</span><strong>寻找变量</strong><small>追踪需求、价格、产能与竞争</small></li>
          <li><span>03</span><strong>回到原文</strong><small>独立核验，不把摘要当结论</small></li>
        </ol>
        <a class="button" href={sitePath("/methodology/")}>了解方法与来源 <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - 4.8rem);
    overflow: hidden;
    padding: clamp(3rem, 7vh, 6.2rem) 0 0;
    position: relative;
  }

  .hero::after {
    background: linear-gradient(90deg, transparent, var(--line-strong), transparent);
    bottom: 0;
    content: "";
    height: 1px;
    left: 0;
    position: absolute;
    right: 0;
  }

  .hero-glow {
    animation: hero-glow-drift 9s ease-in-out infinite alternate;
    background: radial-gradient(circle, rgba(83, 213, 245, 0.12), transparent 65%);
    filter: blur(2px);
    height: 40rem;
    pointer-events: none;
    position: absolute;
    right: -9rem;
    top: -7rem;
    width: 46rem;
  }

  @keyframes hero-glow-drift {
    from { opacity: 0.7; transform: translate3d(-2rem, -1rem, 0) scale(0.94); }
    to { opacity: 1; transform: translate3d(1.5rem, 1rem, 0) scale(1.06); }
  }

  .hero-grid {
    align-items: center;
    display: grid;
    gap: clamp(3rem, 7vw, 7rem);
    grid-template-columns: minmax(0, 1.08fr) minmax(27rem, 0.92fr);
  }

  .hero-overline {
    align-items: center;
    color: var(--text-dim);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    gap: 0.65rem;
    letter-spacing: 0.11em;
    margin-bottom: 1.8rem;
  }

  .status-pulse {
    animation: status-pulse 2.2s ease-in-out infinite;
    background: var(--mint);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(99, 230, 190, 0.75);
    height: 0.42rem;
    width: 0.42rem;
  }

  @keyframes status-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(99, 230, 190, 0.34), 0 0 12px rgba(99, 230, 190, 0.75); }
    50% { box-shadow: 0 0 0 0.38rem rgba(99, 230, 190, 0), 0 0 18px rgba(99, 230, 190, 0.9); }
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 7vw, 6.8rem);
    font-weight: 500;
    letter-spacing: -0.065em;
    line-height: 0.98;
    margin: 0;
  }

  h1 em {
    color: transparent;
    font-style: normal;
    -webkit-text-stroke: 1px rgba(99, 230, 190, 0.85);
  }

  .hero-copy {
    color: var(--text-muted);
    font-size: clamp(0.94rem, 1.3vw, 1.08rem);
    line-height: 1.8;
    margin: 1.8rem 0 0;
    max-width: 35rem;
  }

  .hero-actions {
    margin-top: 2rem;
  }

  .hero-note {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.07em;
    margin: 1.4rem 0 0;
  }

  .signal-panel {
    background: rgba(9, 20, 35, 0.72);
    border: 1px solid var(--line-strong);
    border-radius: 1.2rem;
    box-shadow: 0 2rem 8rem rgba(0, 0, 0, 0.25);
    overflow: hidden;
    position: relative;
  }

  .signal-panel::after {
    animation: panel-scan 6.5s linear infinite;
    background: linear-gradient(90deg, transparent, rgba(99, 230, 190, 0.16), transparent);
    content: "";
    height: 1px;
    left: 0;
    pointer-events: none;
    position: absolute;
    right: 0;
    top: 0;
    z-index: 8;
  }

  @keyframes panel-scan {
    from { opacity: 0; transform: translateY(0); }
    12%, 88% { opacity: 1; }
    to { opacity: 0; transform: translateY(31rem); }
  }

  .panel-head,
  .panel-foot {
    align-items: center;
    color: var(--text-dim);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    justify-content: space-between;
    letter-spacing: 0.1em;
    padding: 0.9rem 1rem;
  }

  .panel-head {
    border-bottom: 1px solid var(--line);
  }

  .panel-live {
    align-items: center;
    display: flex;
    gap: 0.4rem;
  }

  .panel-live i {
    background: var(--amber);
    border-radius: 50%;
    display: inline-block;
    height: 0.32rem;
    width: 0.32rem;
  }

  .chip-diagram {
    aspect-ratio: 1.16;
    background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 3rem 3rem;
    overflow: hidden;
    position: relative;
  }

  .chip-diagram::after {
    background: radial-gradient(circle at center, transparent 20%, rgba(7, 16, 29, 0.83) 72%);
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .chip-core {
    animation: core-breathe 4.8s ease-in-out infinite;
    align-items: center;
    background: #0c1c30;
    border: 1px solid rgba(99, 230, 190, 0.6);
    box-shadow: 0 0 4rem rgba(99, 230, 190, 0.14), inset 0 0 1.3rem rgba(99, 230, 190, 0.06);
    display: flex;
    flex-direction: column;
    height: 7.5rem;
    justify-content: center;
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%) rotate(45deg);
    width: 7.5rem;
    z-index: 4;
  }

  @keyframes core-breathe {
    0%, 100% { box-shadow: 0 0 3rem rgba(99, 230, 190, 0.12), inset 0 0 1.3rem rgba(99, 230, 190, 0.06); }
    50% { box-shadow: 0 0 5.5rem rgba(99, 230, 190, 0.25), inset 0 0 1.8rem rgba(99, 230, 190, 0.12); }
  }

  .chip-core::before,
  .chip-core::after {
    border: 1px solid var(--line-strong);
    content: "";
    inset: 0.65rem;
    position: absolute;
  }

  .chip-core::after {
    inset: 1.1rem;
  }

  .chip-core span,
  .chip-core small {
    position: relative;
    transform: rotate(-45deg);
    z-index: 2;
  }

  .chip-core span {
    color: var(--mint);
    font-family: var(--font-display);
    font-size: 1.7rem;
  }

  .chip-core small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.44rem;
    letter-spacing: 0.12em;
    margin-top: -0.2rem;
  }

  .orbit {
    animation: orbit-turn 18s linear infinite;
    border: 1px solid var(--line);
    border-radius: 50%;
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .orbit-a { height: 15rem; width: 15rem; }
  .orbit-b { animation-direction: reverse; animation-duration: 27s; height: 22rem; width: 22rem; }

  .orbit::after {
    background: var(--mint);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--mint);
    content: "";
    height: 0.3rem;
    left: 50%;
    position: absolute;
    top: -0.16rem;
    width: 0.3rem;
  }

  @keyframes orbit-turn {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  .diagram-node {
    animation: diagram-float 4s ease-in-out infinite;
    align-items: center;
    color: var(--text-dim);
    display: grid;
    font-family: var(--font-mono);
    font-size: 0.47rem;
    gap: 0.2rem 0.4rem;
    grid-template-columns: auto 1fr;
    letter-spacing: 0.04em;
    position: absolute;
    z-index: 5;
  }

  .diagram-node:nth-of-type(3n) { animation-delay: -1.4s; }
  .diagram-node:nth-of-type(3n + 1) { animation-delay: -2.7s; }

  @keyframes diagram-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-0.28rem); }
  }

  .diagram-node i {
    background: var(--node-color);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--node-color);
    grid-row: 1 / 3;
    height: 0.42rem;
    width: 0.42rem;
  }

  .diagram-node strong {
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 500;
  }

  .node-1 { left: 9%; top: 12%; }
  .node-2 { left: 42%; top: 5%; }
  .node-3 { right: 8%; top: 12%; }
  .node-4 { right: 1%; top: 39%; }
  .node-5 { bottom: 13%; right: 8%; }
  .node-6 { bottom: 5%; left: 42%; }
  .node-7 { bottom: 13%; left: 9%; }
  .node-8 { left: 1%; top: 52%; }
  .node-9 { left: 5%; top: 30%; }

  .panel-foot {
    border-top: 1px solid var(--line);
    justify-content: center;
  }

  .panel-foot i {
    background: var(--line-strong);
    height: 1px;
    margin: 0 0.65rem;
    width: 2.2rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: clamp(3.3rem, 7vh, 6rem);
  }

  .hero-stats div {
    border-left: 1px solid var(--line);
    display: grid;
    gap: 0.25rem;
    padding: 1.15rem 1.35rem;
  }

  .hero-stats div:last-child {
    border-right: 1px solid var(--line);
  }

  .hero-stats strong {
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 500;
  }

  .hero-stats span {
    color: var(--text-dim);
    font-size: 0.65rem;
  }

  .chain-section {
    padding-bottom: 5rem;
  }

  .stage-grid {
    border-bottom: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .theme-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, 1fr);
  }

  .theme-card {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 1rem;
    min-height: 28rem;
    overflow: hidden;
    padding: 1.5rem;
    position: relative;
    transition: border-color 220ms ease, transform 220ms ease, box-shadow 220ms ease;
  }

  .theme-card:hover {
    border-color: color-mix(in srgb, var(--card-color) 38%, var(--line));
    box-shadow: 0 1.5rem 4rem color-mix(in srgb, var(--card-color) 8%, transparent);
    transform: translateY(-0.35rem);
  }

  .theme-card::before {
    background: radial-gradient(circle, var(--card-color), transparent 67%);
    content: "";
    height: 15rem;
    opacity: 0.09;
    position: absolute;
    right: -7rem;
    top: -7rem;
    width: 15rem;
  }

  .theme-card.cyan { --card-color: var(--cyan); }
  .theme-card.amber { --card-color: var(--amber); }
  .theme-card.violet { --card-color: var(--violet); }

  .theme-number {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    margin-bottom: 3.4rem;
  }

  .theme-eyebrow {
    color: var(--card-color);
    font-size: 0.7rem;
  }

  .theme-card h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
    margin: 0.4rem 0 0;
  }

  .theme-card > p {
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.75;
    margin: 1rem 0;
  }

  .theme-card blockquote {
    border-left: 1px solid var(--card-color);
    color: var(--text-strong);
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.5;
    margin: 1.3rem 0;
    padding-left: 0.9rem;
  }

  .theme-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .theme-signals span {
    background: rgba(255, 255, 255, 0.04);
    border-radius: 0.35rem;
    color: var(--text-dim);
    font-size: 0.6rem;
    padding: 0.35rem 0.45rem;
  }

  .theme-card > a {
    align-items: center;
    bottom: 1.5rem;
    color: var(--text-muted);
    display: flex;
    font-size: 0.76rem;
    justify-content: space-between;
    left: 1.5rem;
    position: absolute;
    right: 1.5rem;
    text-decoration: none;
  }

  .theme-card > a span {
    color: var(--card-color);
  }

  .featured-grid {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(3, 1fr);
  }

  .intelligence-preview {
    background: linear-gradient(180deg, rgba(83, 213, 245, 0.025), transparent 70%);
  }

  .news-preview-grid {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .method-preview {
    padding-bottom: 2rem;
  }

  .method-grid {
    display: grid;
    gap: 6rem;
    grid-template-columns: 0.8fr 1.2fr;
  }

  .method-copy > p {
    color: var(--text-muted);
    line-height: 1.9;
    margin: 0 0 2rem;
    max-width: 38rem;
  }

  .method-copy ol {
    border-top: 1px solid var(--line);
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
  }

  .method-copy li {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 1rem;
    grid-template-columns: 2rem 8rem 1fr;
    padding: 1.15rem 0;
  }

  .method-copy li span {
    color: var(--mint);
    font-family: var(--font-mono);
    font-size: 0.6rem;
  }

  .method-copy li strong {
    font-size: 0.83rem;
  }

  .method-copy li small {
    color: var(--text-dim);
    font-size: 0.78rem;
  }

  @media (max-width: 1050px) {
    .hero-grid {
      grid-template-columns: 1fr 0.9fr;
    }

    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .news-preview-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 820px) {
    .hero {
      min-height: 0;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .signal-panel {
      margin-inline: auto;
      max-width: 32rem;
      width: 100%;
    }

    .theme-grid {
      grid-template-columns: 1fr;
    }

    .theme-card {
      min-height: 25rem;
    }

    .method-grid {
      gap: 2.5rem;
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    h1 {
      font-size: clamp(2.6rem, 11vw, 4.2rem);
      word-break: keep-all;
    }

    h1 span {
      white-space: nowrap;
    }

    .hero-stats {
