---
import BaseLayout from "../layouts/BaseLayout.astro";
import AiExportPanel from "../components/AiExportPanel.astro";
import NewsCard from "../components/NewsCard.astro";
import { newsArticles, newsSnapshot, newsSourceStatuses, newsSourceTypes, newsTopics, newsDisplaySummary, newsDisplayTitle } from "../data/news";
import { formatDate } from "../data/updates";

const featured = newsArticles.find((article) => article.id === "bis-bulletin-128") ?? newsArticles[0];
const relatedPerspective = newsArticles.find((article) => article.id === "blackstone-2026-mid-year");
const articleCount = newsArticles.length;
const healthySources = newsSourceStatuses.filter((source) => source.status === "ok").length;
const timelineDateKey = new Intl.DateTimeFormat("en-CA", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: "Asia/Shanghai",
});
const timelineGroups = Object.entries(
  newsArticles.reduce<Record<string, typeof newsArticles>>((groups, article) => {
    const key = timelineDateKey.format(new Date(article.publishedAt));
    (groups[key] ??= []).push(article);
    return groups;
  }, {}),
).sort(([left], [right]) => right.localeCompare(left)).map(([date, articles]) => {
  const value = new Date(`${date}T00:00:00+08:00`);
  return {
    date,
    articles: [...articles].sort((left, right) => right.publishedAt.localeCompare(left.publishedAt)),
    day: new Intl.DateTimeFormat("zh-CN", { day: "2-digit", timeZone: "Asia/Shanghai" }).format(value),
    month: new Intl.DateTimeFormat("zh-CN", { month: "short", timeZone: "Asia/Shanghai" }).format(value),
    year: Number(date.slice(0, 4)),
    weekday: new Intl.DateTimeFormat("zh-CN", { weekday: "short", timeZone: "Asia/Shanghai" }).format(value),
  };
});
---

<BaseLayout
  title="权威情报 · 智芯图谱"
  description="聚合 AI 与半导体产业链的国际机构研究、央行分析和公司一手观点，并生成有证据边界的中文 AI 摘要。"
  active="news"
>
  <section class="page-hero intelligence-hero">
    <div class="shell page-hero-grid">
      <div>
        <span class="eyebrow">Authority intelligence</span>
        <h1 class="display-title">权威信息，<br /><em>串成产业信号</em></h1>
      </div>
      <div>
        <p class="page-kicker">定时跟踪国际机构、央行研究与产业一手文章。AI 负责归纳变化和价值链影响，所有判断保留原文入口与来源立场。</p>
        <div class="page-meta"><span><i></i>{articleCount} 篇有效情报</span><span>{newsSnapshot.sourceCount} 个来源</span><span>更新于 {formatDate(newsSnapshot.generatedAt)}</span></div>
      </div>
    </div>
  </section>

  {featured && (
    <section class="section spotlight-section">
      <div class="shell">
        <div class="section-head">
          <div>
            <span class="eyebrow">Current signal</span>
            <h2 class="section-title">本期关联：AI 扰动如何穿透到资本</h2>
            <p class="section-copy">把独立机构的风险研究与资产管理机构的市场观点并排阅读，但不把两种立场混为一谈。</p>
          </div>
          <span class="pipeline-health"><i></i>{healthySources}/{newsSourceStatuses.length} 个自动源正常</span>
        </div>
        <div class="spotlight-grid">
          <article class="spotlight-main">
            <div class="spotlight-meta"><span>{featured.sourceType}</span><strong>{featured.sourceName}</strong><time>{formatDate(featured.publishedAt)}</time></div>
            <h3><a href={featured.url} target="_blank" rel="noreferrer">{newsDisplayTitle(featured)} <span>↗</span></a></h3>
            <p>{newsDisplaySummary(featured)}</p>
            <div class="signal-flow" aria-label="该研究关注的风险传导路径">
              <span>AI 软件扰动</span><i>→</i><span>收入不确定性</span><i>→</i><span>贷款定价</span><i>→</i><span>信用风险</span>
            </div>
            <div class="spotlight-foot"><small>来源观点：独立机构作者研究</small><a href={featured.url} target="_blank" rel="noreferrer">查看 BIS 原文 ↗</a></div>
          </article>
          {relatedPerspective && (
            <article class="perspective-card">
              <span>RELATED PERSPECTIVE</span>
              <strong>{relatedPerspective.sourceName} · {formatDate(relatedPerspective.publishedAt)}</strong>
              <h3>{newsDisplayTitle(relatedPerspective)}</h3>
              <p>{newsDisplaySummary(relatedPerspective)}</p>
              <div class="perspective-note">这是 Blackstone 自身的市场观点，并非 BIS 对 Blackstone 的点名分析。</div>
              <a href={relatedPerspective.url} target="_blank" rel="noreferrer">阅读公司原文 <span>↗</span></a>
            </article>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="section section-rule news-index">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Intelligence stream</span>
          <h2 class="section-title">综合情报流</h2>
          <p class="section-copy">只收录与产业链相关的权威来源；公司文章会明确标为“公司观点”，不等同于独立研究。</p>
        </div>
        <span class="visible-count"><strong data-visible-count>{articleCount}</strong> / {articleCount} ARTICLES</span>
      </div>

      <div class="filter-panel news-filters">
        <label class="search-field">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor"/><path d="m16 16 5 5" stroke="currentColor"/></svg>
          <span class="sr-only">搜索情报</span>
          <input data-news-search type="search" placeholder="搜索标题、机构、公司或产业主题" />
        </label>
        <div class="filter-selects">
          <select data-topic-filter aria-label="按主题筛选">
            <option value="all">全部主题</option>
            {newsTopics.map((topic) => <option value={topic}>{topic}</option>)}
          </select>
          <select data-source-filter aria-label="按来源类型筛选">
            <option value="all">全部来源</option>
            {newsSourceTypes.map((type) => <option value={type}>{type}</option>)}
          </select>
          <select data-perspective-filter aria-label="按来源立场筛选">
            <option value="all">全部立场</option>
            <option value="independent">仅独立来源</option>
            <option value="company">仅公司观点</option>
          </select>
        </div>
      </div>

      <div class="news-timeline" data-news-timeline>
        {timelineGroups.map((group) => (
          <section class="timeline-group" data-timeline-group>
            <header class="timeline-date">
              <span>{group.day}</span>
              <div><strong>{group.month}</strong><small>{group.year} · {group.weekday}</small></div>
              <i></i>
            </header>
            <div class="timeline-items">
              <div class="date-summary"><span>{group.date}</span><small data-group-count>{group.articles.length} ARTICLES</small></div>
              {group.articles.map((article) => <NewsCard article={article} />)}
            </div>
          </section>
        ))}
      </div>
      <div class="empty-state" data-news-empty>没有找到匹配的权威情报，请调整关键词或筛选条件。</div>

      <aside class="method-note">
        <span>COLLECTION BOUNDARY</span>
        <p>“全网”在这里指可持续维护的权威来源覆盖，不抓取匿名转载或把搜索结果直接当事实。当前自动源以官方 RSS 为主，重点机构文章由维护清单补充；AI 只处理标题、官方摘要或已核验要点，不读取不到的正文。</p>
      </aside>
      <div class="news-export"><AiExportPanel compact /></div>
    </div>
  </section>

  <script>
    const search = document.querySelector<HTMLInputElement>("[data-news-search]");
    const topic = document.querySelector<HTMLSelectElement>("[data-topic-filter]");
    const source = document.querySelector<HTMLSelectElement>("[data-source-filter]");
    const perspective = document.querySelector<HTMLSelectElement>("[data-perspective-filter]");
    const cards = [...document.querySelectorAll<HTMLElement>("[data-news-card]")];
    const groups = [...document.querySelectorAll<HTMLElement>("[data-timeline-group]")];
    const count = document.querySelector<HTMLElement>("[data-visible-count]");
    const empty = document.querySelector<HTMLElement>("[data-news-empty]");

    const filterCards = () => {
      const query = search?.value.trim().toLowerCase() ?? "";
      const selectedTopic = topic?.value ?? "all";
      const selectedSource = source?.value ?? "all";
      const selectedPerspective = perspective?.value ?? "all";
      let visible = 0;
      cards.forEach((card) => {
        const matchesSearch = !query || (card.dataset.search ?? "").includes(query);
        const matchesTopic = selectedTopic === "all" || (card.dataset.topics ?? "").split("|").includes(selectedTopic);
        const matchesSource = selectedSource === "all" || card.dataset.sourceType === selectedSource;
        const matchesPerspective = selectedPerspective === "all" || card.dataset.perspective === selectedPerspective;
        const show = matchesSearch && matchesTopic && matchesSource && matchesPerspective;
        card.hidden = !show;
        if (show) visible += 1;
      });
      groups.forEach((group) => {
        const groupCards = [...group.querySelectorAll<HTMLElement>("[data-news-card]")];
        const groupVisible = groupCards.filter((card) => !card.hidden).length;
        group.hidden = groupVisible === 0;
        const groupCount = group.querySelector<HTMLElement>("[data-group-count]");
        if (groupCount) groupCount.textContent = `${groupVisible} ${groupVisible === 1 ? "ARTICLE" : "ARTICLES"}`;
      });
      if (count) count.textContent = String(visible);
      empty?.classList.toggle("visible", visible === 0);
    };

    search?.addEventListener("input", filterCards);
    topic?.addEventListener("change", filterCards);
    source?.addEventListener("change", filterCards);
    perspective?.addEventListener("change", filterCards);
  </script>
</BaseLayout>

<style>
  .intelligence-hero {
    background:
      linear-gradient(90deg, rgba(7, 16, 29, 0.96), rgba(7, 16, 29, 0.7)),
      radial-gradient(circle at 82% 32%, rgba(167, 139, 250, 0.16), transparent 25rem);
  }

  .intelligence-hero .display-title em {
    white-space: nowrap;
  }

  .spotlight-section {
    padding-top: 5rem;
  }

  .pipeline-health,
  .visible-count {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .pipeline-health {
    align-items: center;
    display: inline-flex;
    gap: 0.5rem;
  }

  .pipeline-health i {
    animation: status-pulse 2.2s ease-in-out infinite;
    background: var(--mint);
    border-radius: 50%;
    height: 0.35rem;
    width: 0.35rem;
  }

  .spotlight-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1.5fr) minmax(19rem, 0.72fr);
  }

  .spotlight-main,
  .perspective-card {
    background: rgba(9, 20, 35, 0.86);
    border: 1px solid var(--line-strong);
    border-radius: 1.2rem;
    overflow: hidden;
    padding: clamp(1.4rem, 3vw, 2.4rem);
    position: relative;
  }

  .spotlight-main::after {
    animation: signal-scan 6s linear infinite;
    background: linear-gradient(90deg, transparent, rgba(99, 230, 190, 0.5), transparent);
    content: "";
    height: 1px;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
  }

  @keyframes signal-scan {
    from { transform: translateX(-100%); }
    to { transform: translateX(100%); }
  }

  .spotlight-meta {
    align-items: center;
    color: var(--text-dim);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    gap: 0.8rem;
  }

  .spotlight-meta span {
    border: 1px solid rgba(99, 230, 190, 0.3);
    border-radius: 999px;
    color: var(--mint);
    padding: 0.35rem 0.55rem;
  }

  .spotlight-meta strong {
    color: var(--cyan);
    font-weight: 500;
  }

  .spotlight-main h3 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.7rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin: 1.4rem 0 0;
  }

  .spotlight-main h3 a {
    color: var(--text-strong);
    text-decoration: none;
  }

  .spotlight-main h3 span,
  .perspective-card a span {
    color: var(--mint);
  }

  .spotlight-main > p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.85;
    margin: 1.2rem 0 0;
    max-width: 50rem;
  }

  .signal-flow {
    align-items: center;
    background: rgba(99, 230, 190, 0.035);
    border: 1px solid rgba(99, 230, 190, 0.13);
    border-radius: 0.8rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.5rem;
    padding: 0.9rem;
  }

  .signal-flow span {
    color: var(--text-muted);
    font-size: 0.76rem;
  }

  .signal-flow i {
    color: var(--mint);
    font-style: normal;
  }

  .spotlight-foot {
    align-items: center;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-top: 1.5rem;
    padding-top: 1rem;
  }

  .spotlight-foot small {
    color: var(--text-dim);
    font-size: 0.68rem;
  }

  .spotlight-foot a,
  .perspective-card a {
    color: var(--text-strong);
    font-size: 0.78rem;
    text-decoration: none;
  }

  .perspective-card > span {
    color: var(--violet);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
  }

  .perspective-card > strong {
    color: var(--text-dim);
    display: block;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 400;
    margin-top: 0.8rem;
  }

  .perspective-card h3 {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 500;
    line-height: 1.25;
    margin: 1rem 0 0;
  }

  .perspective-card > p {
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.75;
    margin: 0.9rem 0 0;
  }

  .perspective-note {
    background: rgba(245, 185, 113, 0.055);
    border: 1px solid rgba(245, 185, 113, 0.18);
    border-radius: 0.7rem;
    color: var(--amber);
    font-size: 0.74rem;
    line-height: 1.6;
    margin: 1.2rem 0;
    padding: 0.7rem;
  }

  .news-index {
    padding-top: 5.5rem;
  }

  .visible-count strong {
    color: var(--mint);
    font-size: 1rem;
  }

  .news-timeline {
    position: relative;
  }

  .news-timeline::before {
    background: linear-gradient(var(--mint), var(--line) 8rem, var(--line) calc(100% - 8rem), transparent);
    bottom: 0;
    content: "";
    left: 7.4rem;
    position: absolute;
    top: 0;
    width: 1px;
  }

  .timeline-group {
    display: grid;
    gap: 2.2rem;
    grid-template-columns: 6.3rem minmax(0, 1fr);
    padding-bottom: 3rem;
    position: relative;
  }

  .timeline-group[hidden] { display: none; }

  .timeline-date {
    align-items: flex-start;
    display: flex;
    gap: 0.65rem;
    padding-top: 0.8rem;
    position: sticky;
    top: 6.5rem;
  }

  .timeline-date > span {
    color: var(--text-strong);
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
  }

  .timeline-date > div { display: grid; gap: 0.2rem; }
  .timeline-date strong { color: var(--mint); font-family: var(--font-mono); font-size: 0.68rem; font-weight: 500; }
  .timeline-date small { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.62rem; white-space: nowrap; }
  .timeline-date i { background: var(--bg); border: 2px solid var(--mint); border-radius: 50%; box-shadow: 0 0 1rem rgba(99, 230, 190, 0.35); height: 0.7rem; position: absolute; right: -1.47rem; top: 1.05rem; width: 0.7rem; z-index: 2; }

  .timeline-items {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(24rem, 100%), 1fr));
    min-width: 0;
  }

  .date-summary {
    align-items: center;
    border-bottom: 1px solid var(--line);
    color: var(--text-dim);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    grid-column: 1 / -1;
    justify-content: space-between;
    padding: 0.75rem 0;
  }

  .date-summary small { color: var(--mint); font-size: 0.62rem; }
  }

  .method-note {
    border-left: 1px solid var(--amber);
    margin-top: 3rem;
    padding: 0.25rem 0 0.25rem 1rem;
  }

  .news-export { margin-top: 3rem; }

  .method-note span {
    color: var(--amber);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
  }

  .method-note p {
    color: var(--text-dim);
    font-size: 0.8rem;
    line-height: 1.7;
    margin: 0.45rem 0 0;
    max-width: 52rem;
  }

  .sr-only {
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    width: 1px;
    clip: rect(0, 0, 0, 0);
  }

  @media (max-width: 900px) {
    .spotlight-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .news-filters {
      grid-template-columns: 1fr;
    }

    .news-filters .filter-selects,
    .news-filters select {
      width: 100%;
    }

    .news-timeline::before { left: 0.35rem; }
    .timeline-group { gap: 1rem; grid-template-columns: 1fr; padding-left: 1.5rem; }
    .timeline-date { align-items: center; position: relative; top: auto; }
    .timeline-date i { left: -1.48rem; right: auto; top: 1.1rem; }
    .timeline-items { grid-template-columns: 1fr; }
  }

  @media (max-width: 520px) {
    .signal-flow {
      align-items: flex-start;
      flex-direction: column;
    }

    .signal-flow i {
      transform: rotate(90deg);
    }

    .spotlight-foot {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
