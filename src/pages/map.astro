---
import BaseLayout from "../layouts/BaseLayout.astro";
import CompanyCard from "../components/CompanyCard.astro";
import { companies } from "../data/companies";
import { industryMapEdges, industryMapNodes, mapZones } from "../data/industry-map";
import { stageByKey, stages } from "../data/stages";
import { sitePath } from "../lib/paths";

const nodeByStage = Object.fromEntries(industryMapNodes.map((node) => [node.stage, node]));
const mapPath = (sourceKey: keyof typeof nodeByStage, targetKey: keyof typeof nodeByStage) => {
  const source = nodeByStage[sourceKey];
  const target = nodeByStage[targetKey];
  const sourceX = source.x * 10;
  const sourceY = source.y * 6;
  const targetX = target.x * 10;
  const targetY = target.y * 6;
  const bend = (targetX - sourceX) * 0.46;
  return `M ${sourceX} ${sourceY} C ${sourceX + bend} ${sourceY}, ${targetX - bend} ${targetY}, ${targetX} ${targetY}`;
};
---

<BaseLayout title="产业地图 · 智芯图谱" description="沿 AI 与半导体价值链查看芯片、基础设施、模型平台与应用环节。" active="map">
  <section class="page-hero map-hero">
    <div class="shell page-hero-grid">
      <div>
        <span class="eyebrow">Industry map</span>
        <h1 class="display-title">一张图，理解<br /><em>AI 完整价值链</em></h1>
      </div>
      <div>
        <p class="page-kicker">从芯片设计与制造走向算力基础设施、模型平台和应用。选择一个环节，查看商业逻辑、跟踪信号和代表公司。</p>
        <div class="page-meta">
          <span><i></i>{stages.length} 个核心环节</span>
          <span>{companies.length} 家代表公司</span>
        </div>
      </div>
    </div>
  </section>

  <section class="map-mode-section section-rule">
    <div class="shell">
      <div class="map-mode-head">
        <div>
          <span class="eyebrow">Two ways to read the chain</span>
          <h2>切换地图视角</h2>
        </div>
        <div class="map-mode-switch" role="toolbar" aria-label="产业地图视图" data-map-mode-switch>
          <button type="button" class="active" data-map-mode="topology" aria-pressed="true">关系地图</button>
          <button type="button" data-map-mode="directory" aria-pressed="false">环节目录</button>
        </div>
      </div>
    </div>
  </section>

  <section class="topology-section" data-map-view-panel="topology">
    <div class="shell topology-layout">
      <div class="topology-main">
        <div class="topology-toolbar">
          <div><i></i><span>点击节点查看上下游关系</span></div>
          <div class="topology-legend"><span><i class="primary"></i>价值流</span><span><i class="feedback"></i>需求反馈</span></div>
        </div>
        <div class="topology-scroll">
          <div class="topology-canvas" data-topology-map>
            {mapZones.map((zone) => (
              <div class={`map-zone zone-${zone.key}`}>
                <span>{zone.label}</span><small>{zone.description}</small>
              </div>
            ))}
            <svg class="edge-layer" viewBox="0 0 1000 600" aria-hidden="true">
              <defs>
                <marker id="map-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
                  <path d="M 0 0 L 10 5 L 0 10 z"></path>
                </marker>
              </defs>
              {industryMapEdges.map((edge) => {
                const source = nodeByStage[edge.source];
                const target = nodeByStage[edge.target];
                return (
                  <g class={`edge-group ${edge.strength}`} data-map-edge data-source={edge.source} data-target={edge.target}>
                    <path class="edge-hit" d={mapPath(edge.source, edge.target)}></path>
                    <path class="map-edge" d={mapPath(edge.source, edge.target)} marker-end="url(#map-arrow)"></path>
                    {edge.strength === "primary" && (
                      <text x={(source.x + target.x) * 5} y={(source.y + target.y) * 3 - 7}>{edge.label}</text>
                    )}
                  </g>
                );
              })}
            </svg>
            {industryMapNodes.map((node) => {
              const stage = stageByKey[node.stage];
              const count = companies.filter((company) => company.stage === node.stage).length;
              return (
                <button
                  type="button"
                  class="topology-node"
                  style={`--node-x: ${node.x}%; --node-y: ${node.y}%; --node-accent: ${stage.accent}`}
                  data-map-node={node.stage}
                  aria-pressed="false"
                >
                  <span>{stage.index}</span>
                  <strong>{stage.name}</strong>
                  <small>{count} COMPANIES</small>
                </button>
              );
            })}
          </div>
        </div>
      </div>

      <aside class="topology-detail" aria-live="polite">
        {stages.map((stage) => {
          const stageCompanies = companies.filter((company) => company.stage === stage.key);
          const connections = industryMapEdges.filter((edge) => edge.source === stage.key || edge.target === stage.key);
          return (
            <article data-map-detail={stage.key} hidden style={`--detail-accent: ${stage.accent}`}>
              <div class="detail-index"><span>{stage.index}</span><small>{stage.nameEn}</small></div>
              <h2>{stage.name}</h2>
              <p>{stage.description}</p>
              <div class="detail-signal"><small>TRACKING SIGNAL</small><strong>{stage.signal}</strong></div>
              <div class="connection-list">
                <small>CONNECTED FLOWS</small>
                {connections.map((edge) => (
                  <div>
                    <i class={edge.strength}></i>
                    <span>{edge.label}</span>
                    <small>{edge.source === stage.key ? "流向下游" : "来自上游"}</small>
                  </div>
                ))}
              </div>
              <div class="detail-companies">
                <small>REPRESENTATIVE COMPANIES</small>
                <div>{stageCompanies.map((company) => <a href={sitePath(`/companies/${company.slug}/`)}>{company.name}<span>↗</span></a>)}</div>
              </div>
            </article>
          );
        })}
      </aside>
    </div>
  </section>

  <section class="map-overview section-rule" data-map-view-panel="directory" hidden>
    <div class="shell">
      <div class="flow-labels">
        <span>上游 · 芯片与制造</span>
        <span>下游 · 算力、模型与应用</span>
      </div>
      <div class="value-flow" aria-label="半导体产业链流程">
        {stages.map((stage, index) => (
          <a href={`#${stage.key}`} class="flow-node" style={`--node-accent: ${stage.accent}`}>
            <span>{stage.index}</span>
            <i aria-hidden="true"></i>
            <strong>{stage.name}</strong>
            <small>{stage.nameEn}</small>
            {index < stages.length - 1 && <b aria-hidden="true">→</b>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section map-browser">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Explore layers</span>
          <h2 class="section-title">按环节探索</h2>
        </div>
        <span class="soft-label"><i></i> 点击切换视图</span>
      </div>

      <div class="stage-tabs" role="toolbar" aria-label="筛选产业环节" data-stage-tabs>
        <button type="button" class="active" data-stage-filter="all" aria-pressed="true">全部环节</button>
        {stages.map((stage) => (
          <button type="button" data-stage-filter={stage.key} aria-pressed="false" style={`--tab-accent: ${stage.accent}`}>
            <i></i>{stage.name}
          </button>
        ))}
      </div>

      <div class="stage-panels" data-stage-panels>
        {stages.map((stage) => {
          const stageCompanies = companies.filter((company) => company.stage === stage.key);
          return (
            <section class="stage-panel" id={stage.key} data-stage-panel={stage.key} style={`--stage-accent: ${stage.accent}`}>
              <header>
                <div class="stage-title-block">
                  <span>{stage.index}</span>
                  <div>
                    <p>{stage.nameEn}</p>
                    <h2>{stage.name}</h2>
                  </div>
                </div>
                <p class="stage-description">{stage.description}</p>
                <div class="signal-box">
                  <small>TRACKING SIGNALS</small>
                  <strong>{stage.signal}</strong>
                </div>
              </header>
              <div class="stage-company-grid">
                {stageCompanies.map((company) => <CompanyCard company={company} compact />)}
              </div>
            </section>
          );
        })}
      </div>

      <div class="map-next">
        <div>
          <span class="eyebrow">Continue</span>
          <h2>从产业位置进入公司研究</h2>
        </div>
        <a class="button primary" href={sitePath("/companies/")}>打开公司目录 <span class="arrow">↗</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const mapModeButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-map-mode]")];
  const mapViewPanels = [...document.querySelectorAll<HTMLElement>("[data-map-view-panel]")];
  const topologyNodes = [...document.querySelectorAll<HTMLButtonElement>("[data-map-node]")];
  const topologyDetails = [...document.querySelectorAll<HTMLElement>("[data-map-detail]")];
  const topologyEdges = [...document.querySelectorAll<SVGGElement>("[data-map-edge]")];

  function selectMapMode(mode: string) {
    mapModeButtons.forEach((button) => {
      const active = button.dataset.mapMode === mode;
      button.classList.toggle("active", active);
      button.setAttribute("aria-pressed", String(active));
    });
    mapViewPanels.forEach((panel) => {
      panel.hidden = panel.dataset.mapViewPanel !== mode;
    });
  }

  function selectTopologyStage(stage: string) {
    topologyNodes.forEach((node) => {
      const active = node.dataset.mapNode === stage;
      node.classList.toggle("active", active);
      node.setAttribute("aria-pressed", String(active));
    });
    topologyDetails.forEach((detail) => {
      detail.hidden = detail.dataset.mapDetail !== stage;
    });
    topologyEdges.forEach((edge) => {
      edge.classList.toggle("active", edge.dataset.source === stage || edge.dataset.target === stage);
      edge.classList.toggle("outgoing", edge.dataset.source === stage);
    });
  }

  mapModeButtons.forEach((button) => button.addEventListener("click", () => selectMapMode(button.dataset.mapMode ?? "topology")));
  topologyNodes.forEach((node) => node.addEventListener("click", () => selectTopologyStage(node.dataset.mapNode ?? "ai-infrastructure")));
  selectTopologyStage("ai-infrastructure");

  const filterButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-stage-filter]")];
  const stagePanels = [...document.querySelectorAll<HTMLElement>("[data-stage-panel]")];

  function selectStage(key: string, updateHash = false) {
    filterButtons.forEach((button) => {
      const active = button.dataset.stageFilter === key;
      button.classList.toggle("active", active);
      button.setAttribute("aria-pressed", String(active));
    });

    stagePanels.forEach((panel) => {
      panel.hidden = key !== "all" && panel.dataset.stagePanel !== key;
    });

    if (updateHash) {
      history.replaceState(null, "", key === "all" ? location.pathname : `#${key}`);
    }
  }

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.dataset.stageFilter ?? "all";
      selectStage(key, true);
    });
  });

  const initialStage = location.hash.slice(1);
  if (stagePanels.some((panel) => panel.dataset.stagePanel === initialStage)) {
    selectStage(initialStage);
  }
</script>

<style>
  .map-hero {
    background: radial-gradient(circle at 82% 65%, rgba(83, 213, 245, 0.08), transparent 23rem);
  }

  .map-overview {
    padding: 3rem 0 4rem;
  }

  [data-map-view-panel][hidden] {
    display: none;
  }

  .map-mode-section {
    padding: 2.2rem 0;
  }

  .map-mode-head {
    align-items: center;
    display: flex;
    gap: 2rem;
    justify-content: space-between;
  }

  .map-mode-head h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 500;
    margin: 0.45rem 0 0;
  }

  .map-mode-switch {
    border: 1px solid var(--line);
    border-radius: 999px;
    display: flex;
    padding: 0.25rem;
  }

  .map-mode-switch button {
    background: transparent;
    border: 0;
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.7rem;
    padding: 0.58rem 0.9rem;
  }

  .map-mode-switch button.active {
    background: var(--mint);
    color: #07101d;
  }

  .topology-section {
    padding: 2rem 0 5rem;
  }

  .topology-layout {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) 20rem;
  }

  .topology-main,
  .topology-detail {
    background: rgba(7, 16, 29, 0.62);
    border: 1px solid var(--line);
  }

  .topology-toolbar {
    align-items: center;
    border-bottom: 1px solid var(--line);
    color: var(--text-dim);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    justify-content: space-between;
    letter-spacing: 0.06em;
    padding: 0.8rem 1rem;
  }

  .topology-toolbar > div,
  .topology-legend span {
    align-items: center;
    display: flex;
    gap: 0.45rem;
  }

  .topology-toolbar > div > i,
  .topology-legend i {
    background: var(--mint);
    border-radius: 50%;
    height: 0.3rem;
    width: 0.3rem;
  }

  .topology-legend {
    display: flex;
    gap: 1rem;
  }

  .topology-legend i.feedback {
    background: var(--violet);
  }

  .topology-scroll {
    overflow-x: auto;
  }

  .topology-canvas {
    background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 3rem 3rem;
    height: 37rem;
    min-width: 62rem;
    overflow: hidden;
    position: relative;
  }

  .topology-canvas::after {
    background: radial-gradient(circle at 55% 45%, transparent, rgba(7, 16, 29, 0.6) 78%);
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 1;
  }

  .map-zone {
    border: 1px solid var(--line);
    border-radius: 1rem;
    display: grid;
    padding: 0.75rem;
    pointer-events: none;
    position: absolute;
    z-index: 2;
  }

  .map-zone span {
    color: rgba(255, 255, 255, 0.18);
    font-family: var(--font-mono);
    font-size: 0.54rem;
    letter-spacing: 0.15em;
  }

  .map-zone small {
    align-self: end;
    color: rgba(255, 255, 255, 0.12);
    font-size: 0.55rem;
  }

  .zone-silicon { inset: 5% 58% 6% 2%; }
  .zone-systems { inset: 5% 20% 6% 43%; }
  .zone-intelligence { inset: 5% 2% 6% 81%; }

  .edge-layer {
    inset: 0;
    position: absolute;
    z-index: 3;
  }

  .edge-layer defs path {
    fill: var(--text-dim);
  }

  .map-edge,
  .edge-hit {
    fill: none;
  }

  .map-edge {
    opacity: 0.38;
    stroke: var(--text-dim);
    stroke-width: 1.4;
    transition: opacity 160ms ease, stroke 160ms ease, stroke-width 160ms ease;
  }

  .edge-group.feedback .map-edge {
    stroke: var(--violet);
    stroke-dasharray: 5 6;
  }

  .edge-group.secondary .map-edge {
    stroke-dasharray: 2 5;
  }

  .edge-group.active .map-edge {
    opacity: 0.95;
    stroke: var(--mint);
    stroke-width: 2.4;
  }

  .edge-group.active.feedback .map-edge {
    stroke: var(--violet);
  }

  .edge-hit {
    stroke: transparent;
    stroke-width: 14;
  }

  .edge-layer text {
    fill: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 8px;
    opacity: 0.55;
    text-anchor: middle;
  }

  .edge-group.active text {
    fill: var(--mint);
    opacity: 1;
  }

  .topology-node {
    background: #0b192a;
    border: 1px solid color-mix(in srgb, var(--node-accent) 42%, var(--line));
    border-radius: 0.75rem;
    color: var(--text-strong);
    display: grid;
    left: var(--node-x);
    min-width: 7.2rem;
    padding: 0.7rem 0.8rem;
    position: absolute;
    text-align: left;
    top: var(--node-y);
    transform: translate(-50%, -50%);
    transition: box-shadow 160ms ease, transform 160ms ease, background 160ms ease;
    z-index: 5;
  }

  .topology-node::before {
    background: var(--node-accent);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--node-accent);
    content: "";
    height: 0.38rem;
    position: absolute;
    right: 0.7rem;
    top: 0.7rem;
    width: 0.38rem;
  }

  .topology-node > span,
  .topology-node small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.46rem;
    letter-spacing: 0.07em;
  }

  .topology-node strong {
    font-size: 0.78rem;
    margin: 0.55rem 0 0.3rem;
  }

  .topology-node:hover,
  .topology-node.active {
    background: color-mix(in srgb, var(--node-accent) 12%, #0b192a);
    box-shadow: 0 0 2rem color-mix(in srgb, var(--node-accent) 20%, transparent);
    transform: translate(-50%, -50%) scale(1.05);
  }

  .topology-detail {
    min-height: 41.3rem;
    padding: 1.25rem;
    position: sticky;
    top: 5.5rem;
  }

  .topology-detail article[hidden] {
    display: none;
  }

  .detail-index {
    align-items: center;
    display: flex;
    justify-content: space-between;
  }

  .detail-index span {
    color: var(--detail-accent);
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .detail-index small,
  .connection-list > small,
  .detail-companies > small,
  .detail-signal small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.08em;
  }

  .topology-detail h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    margin: 2.8rem 0 0.8rem;
  }

  .topology-detail article > p {
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.75;
  }

  .detail-signal {
    border-left: 1px solid var(--detail-accent);
    display: grid;
    gap: 0.5rem;
    margin: 1.5rem 0;
    padding-left: 0.8rem;
  }

  .detail-signal strong {
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 500;
    line-height: 1.55;
  }

  .connection-list {
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  .connection-list > div {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0.5rem;
    grid-template-columns: 0.4rem 1fr auto;
    padding: 0.65rem 0;
  }

  .connection-list i {
    background: var(--mint);
    border-radius: 50%;
    height: 0.3rem;
    width: 0.3rem;
  }

  .connection-list i.feedback { background: var(--violet); }
  .connection-list span { color: var(--text-muted); font-size: 0.62rem; }
  .connection-list div small { color: var(--text-dim); font-size: 0.5rem; }

  .detail-companies {
    margin-top: 1.4rem;
  }

  .detail-companies > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.7rem;
  }

  .detail-companies a {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.55rem;
    padding: 0.35rem 0.5rem;
    text-decoration: none;
  }

  .detail-companies a span { color: var(--detail-accent); }

  .flow-labels {
    color: var(--text-dim);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    justify-content: space-between;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .value-flow {
    border: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    min-width: 84rem;
  }

  .map-overview .shell {
    overflow-x: auto;
    scrollbar-color: var(--line-strong) transparent;
  }

  .flow-node {
    border-right: 1px solid var(--line);
    color: var(--text-muted);
    display: grid;
    min-height: 10rem;
    padding: 1rem;
    position: relative;
    text-decoration: none;
    transition: background 160ms ease;
  }

  .flow-node:last-child {
    border-right: 0;
  }

  .flow-node:hover {
    background: color-mix(in srgb, var(--node-accent) 7%, transparent);
  }

  .flow-node > span {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.55rem;
  }

  .flow-node i {
    background: var(--node-accent);
    box-shadow: 0 0 16px var(--node-accent);
    height: 1px;
    margin: 1.4rem 0 1.1rem;
    opacity: 0.75;
    width: 2.1rem;
  }

  .flow-node strong {
    color: var(--text-strong);
    font-size: 0.9rem;
  }

  .flow-node small {
    align-self: end;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.08em;
    margin-top: 0.35rem;
    text-transform: uppercase;
  }

  .flow-node b {
    color: var(--node-accent);
    font-weight: 400;
    position: absolute;
    right: -0.38rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
  }

  .stage-tabs {
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 0.4rem;
    margin-bottom: 3rem;
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .stage-tabs button {
    align-items: center;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-muted);
    display: inline-flex;
    flex: 0 0 auto;
    font-size: 0.7rem;
    gap: 0.45rem;
    padding: 0.58rem 0.8rem;
  }

  .stage-tabs button i {
    background: var(--tab-accent, var(--mint));
    border-radius: 50%;
    height: 0.3rem;
    opacity: 0.65;
