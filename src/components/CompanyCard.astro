---
import type { Company } from "../data/companies";
import { stageByKey } from "../data/stages";
import { sitePath } from "../lib/paths";

interface Props {
  company: Company;
  compact?: boolean;
  watchable?: boolean;
}

const { company, compact = false, watchable = false } = Astro.props;
const stage = stageByKey[company.stage];
---

<article
  class:list={["company-card", { compact }]}
  style={`--company-accent: ${stage.accent}`}
  data-company-card
  data-company={company.slug}
  data-stage={company.stage}
  data-market={company.exchange}
  data-search={`${company.name} ${company.nameEn} ${company.ticker} ${company.focus.join(" ")}`.toLowerCase()}
>
  <a class="company-card-hit" href={sitePath(`/companies/${company.slug}/`)} aria-label={`查看${company.name}研究卡`}></a>
  {watchable && <button class="watch-toggle" type="button" data-watch-company={company.slug} aria-label={`关注${company.name}`} aria-pressed="false"><span aria-hidden="true">＋</span><b>关注</b></button>}
  <div class="company-card-top">
    <span class="ticker">{company.ticker}</span>
    <span class="stage-dot"><i></i>{stage.name}</span>
  </div>
  <div>
    <h3>{company.name}</h3>
    <p class="company-en">{company.nameEn} · {company.exchange}</p>
  </div>
  {!compact && <p class="company-description">{company.description}</p>}
  <div class="tag-list">
    {company.focus.slice(0, compact ? 2 : 3).map((tag) => <span>{tag}</span>)}
  </div>
  <span class="card-link">
    查看研究卡 <span aria-hidden="true">↗</span>
  </span>
</article>

<style>
  .company-card {
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012));
    border: 1px solid var(--line);
    border-radius: 1.1rem;
    display: flex;
    flex-direction: column;
    min-height: 20rem;
    overflow: hidden;
    padding: 1.35rem;
    position: relative;
    text-decoration: none;
    transition: border-color 220ms ease, transform 220ms ease, background 220ms ease, box-shadow 220ms ease;
  }

  .company-card-hit {
    border-radius: inherit;
    inset: 0;
    position: absolute;
    z-index: 2;
  }

  .company-card-hit:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--company-accent) 55%, transparent);
    outline-offset: -3px;
  }

  .watch-toggle {
    align-items: center;
    background: rgba(7, 16, 29, 0.86);
    border: 1px solid var(--line);
    border-radius: 999px;
    bottom: 1rem;
    color: var(--text-muted);
    display: inline-flex;
    font-size: 0.7rem;
    gap: 0.35rem;
    padding: 0.38rem 0.55rem;
    position: absolute;
    right: 1rem;
    z-index: 3;
  }

  .watch-toggle b { font-weight: 500; }
  .watch-toggle span { color: var(--mint); }
  .watch-toggle[aria-pressed="true"] { background: rgba(99, 230, 190, 0.12); border-color: rgba(99, 230, 190, 0.42); color: var(--text-strong); }
  .watch-toggle[aria-pressed="true"] span { transform: rotate(45deg); }

  .company-card[hidden] {
    display: none;
  }

  .company-card::before {
    background: var(--company-accent);
    content: "";
    height: 1px;
    left: 1.35rem;
    opacity: 0.75;
    position: absolute;
    right: 72%;
    top: 0;
  }

  .company-card::after {
    background: linear-gradient(110deg, transparent 28%, color-mix(in srgb, var(--company-accent) 13%, transparent) 48%, transparent 68%);
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
    transform: translateX(-115%);
    transition: transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .company-card:hover {
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018));
    border-color: var(--line-strong);
    box-shadow: 0 1.4rem 3.5rem color-mix(in srgb, var(--company-accent) 10%, transparent);
    transform: translateY(-5px);
  }

  .company-card:hover::after,
  .company-card:focus-visible::after {
    transform: translateX(115%);
  }

  .company-card.compact {
    min-height: 16.5rem;
  }

  .company-card-top {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin-bottom: 2.2rem;
  }

  .ticker {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-strong);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.55rem;
  }

  .stage-dot {
    align-items: center;
    color: var(--text-dim);
    display: inline-flex;
    font-size: 0.7rem;
    gap: 0.4rem;
  }

  .stage-dot i {
    background: var(--company-accent);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--company-accent);
    display: inline-block;
    height: 0.38rem;
    width: 0.38rem;
  }

  h3 {
    font-size: 1.35rem;
    margin: 0;
  }

  .company-en {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    margin: 0.4rem 0 0;
  }

  .company-description {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.75;
    margin: 1.2rem 0;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 1.2rem;
  }

  .tag-list span {
    background: rgba(255, 255, 255, 0.04);
    border-radius: 0.4rem;
    color: var(--text-muted);
    font-size: 0.68rem;
    padding: 0.35rem 0.5rem;
  }

  .card-link {
    align-items: center;
    border-top: 1px solid var(--line);
    color: var(--text-muted);
    display: flex;
    font-size: 0.78rem;
    justify-content: space-between;
    margin-top: 1.15rem;
    padding-top: 1rem;
    text-decoration: none;
  }

  .company-card:has(.watch-toggle) .card-link { padding-right: 5rem; }

  .card-link span {
    color: var(--company-accent);
    transition: transform 180ms ease;
  }

  .company-card:hover .card-link {
    color: var(--text-strong);
  }

  .company-card:hover .card-link span,
  .company-card:focus-visible .card-link span {
    transform: translate(0.16rem, -0.12rem);
  }
</style>
