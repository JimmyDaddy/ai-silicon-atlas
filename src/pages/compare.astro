---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCompanyAnalysis } from "../data/analysis";
import { companies } from "../data/companies";
import { stageByKey } from "../data/stages";
import { getCompanyUpdate, metricChange } from "../data/updates";
import { sitePath } from "../lib/paths";

const metricNames: Record<string, string> = { revenue: "收入", netIncome: "净利润", assets: "总资产", cash: "现金", capex: "资本开支" };
const compareData = companies.map((company) => {
  const update = getCompanyUpdate(company.slug);
  const analysis = getCompanyAnalysis(company.slug);
  return {
    slug: company.slug,
    name: company.name,
    nameEn: company.nameEn,
    ticker: company.ticker,
    exchange: company.exchange,
    country: company.country,
    stage: { key: company.stage, name: stageByKey[company.stage].name, accent: stageByKey[company.stage].accent },
    description: company.description,
    focus: company.focus,
    attention: company.attention,
    risks: company.risks,
    pageUrl: sitePath(`/companies/${company.slug}/`),
    dataStatus: update ? { status: update.status, stale: Boolean(update.stale), checkedAt: update.checkedAt } : null,
    latestFiling: update?.latestFiling ?? null,
    metrics: Object.entries(update?.metrics ?? {}).map(([key, metric]) => ({
      key,
      name: metricNames[key] ?? metric.label ?? key,
      value: metric.value,
      unit: metric.unit,
      periodEnd: metric.periodEnd,
      change: metricChange(update?.metricHistory?.[key]),
    })),
    analysis: analysis ? {
      status: analysis.status,
      summary: analysis.summary ?? analysis.reason ?? "暂无可用综合分析。",
      confidence: analysis.confidence ?? null,
      generatedAt: analysis.generatedAt,
    } : null,
  };
});
const serializedCompareData = JSON.stringify(compareData).replace(/</g, "\\u003c");
---

<BaseLayout title="公司比较 · 智芯图谱" description="并排比较 AI 与半导体产业链公司的位置、财务快照、官方披露、研究重点和风险。" active="compare">
  <section class="page-hero compare-hero">
    <div class="shell page-hero-grid">
      <div><span class="eyebrow">Company comparison</span><h1 class="display-title">少看孤立数字，<br />多做<em>横向比较</em></h1></div>
      <div><p class="page-kicker">最多选择四家公司，并排比较产业位置、最新披露、结构化指标、AI 综合分析和待跟踪风险。</p><div class="page-meta"><span><i></i>{companies.length} 家可比较公司</span><span>浏览器本地关注列表</span></div></div>
    </div>
  </section>

  <section class="compare-workspace section-rule">
    <div class="shell">
      <div class="picker-panel">
        <div class="picker-head"><div><span class="eyebrow">Selection</span><h2>选择 2–4 家公司</h2></div><div class="picker-actions"><button type="button" data-use-watchlist>载入我的关注</button><button type="button" data-copy-link>复制比较链接</button></div></div>
        <label class="compare-search"><span class="sr-only">搜索可比较公司</span><input type="search" data-compare-search placeholder="搜索公司、代码或产业环节" /></label>
        <div class="picker-rail">
          <button class="picker-nav previous" type="button" data-picker-previous aria-label="向左浏览公司"><span aria-hidden="true">←</span></button>
          <div class="company-picker" data-company-picker tabindex="0" aria-label="横向滚动选择公司">
            {companies.map((company) => (
              <button type="button" data-compare-company={company.slug} data-search={`${company.name} ${company.nameEn} ${company.ticker} ${stageByKey[company.stage].name}`.toLowerCase()} aria-pressed="false">
                <span>{company.ticker}</span><strong>{company.name}</strong><small>{stageByKey[company.stage].name}</small><i aria-hidden="true">＋</i>
              </button>
            ))}
          </div>
          <button class="picker-nav next" type="button" data-picker-next aria-label="向右浏览公司"><span aria-hidden="true">→</span></button>
        </div>
        <div class="picker-foot"><p class="picker-message" data-picker-message aria-live="polite">最多同时比较四家公司。</p><span>横向滑动浏览全部 {companies.length} 家公司</span></div>
      </div>

      <div class="selection-summary">
        <div><span class="eyebrow">Selected set</span><p data-selection-label></p><div class="selection-chips" data-selection-chips></div></div>
        <div class="selection-side"><span><b data-selection-count>0</b> / 4</span><a href={sitePath("/companies/")}>返回公司目录 ↗</a></div>
      </div>
      <div class="compare-scroll" tabindex="0" aria-label="横向滚动查看公司比较结果"><div class="compare-grid" data-compare-grid></div></div>
      <div class="empty-state" data-compare-empty>至少选择一家公司后才能开始比较。</div>
    </div>
  </section>

  <script is:inline type="application/json" id="compare-data" set:html={serializedCompareData}></script>
  <script>
    interface CompareCompany {
      slug: string; name: string; nameEn: string; ticker: string; exchange: string; country: string;
      stage: { key: string; name: string; accent: string }; description: string; focus: string[]; attention: string[]; risks: string[];
      pageUrl: string; dataStatus: { status: string; stale: boolean; checkedAt: string } | null;
      latestFiling: { form: string; filedAt: string; title: string; url: string } | null;
      metrics: Array<{ key: string; name: string; value: number; unit: string; periodEnd: string; change: number | null }>;
      analysis: { status: string; summary: string; confidence: string | null; generatedAt: string | null } | null;
    }

    const rawData = document.querySelector<HTMLScriptElement>("#compare-data")?.textContent ?? "[]";
    const companyData = JSON.parse(rawData) as CompareCompany[];
    const bySlug = new Map(companyData.map((company) => [company.slug, company]));
    const pickerButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-compare-company]")];
    const picker = document.querySelector<HTMLElement>("[data-company-picker]");
    const pickerPrevious = document.querySelector<HTMLButtonElement>("[data-picker-previous]");
    const pickerNext = document.querySelector<HTMLButtonElement>("[data-picker-next]");
    const search = document.querySelector<HTMLInputElement>("[data-compare-search]");
    const grid = document.querySelector<HTMLElement>("[data-compare-grid]");
    const empty = document.querySelector<HTMLElement>("[data-compare-empty]");
    const message = document.querySelector<HTMLElement>("[data-picker-message]");
    const selectionLabel = document.querySelector<HTMLElement>("[data-selection-label]");
    const selectionChips = document.querySelector<HTMLElement>("[data-selection-chips]");
    const selectionCount = document.querySelector<HTMLElement>("[data-selection-count]");
    const useWatchlist = document.querySelector<HTMLButtonElement>("[data-use-watchlist]");
    const copyLink = document.querySelector<HTMLButtonElement>("[data-copy-link]");
    const storageKey = "silicon-atlas-watchlist-v1";
    const params = new URLSearchParams(location.search);
    const fromQuery = (params.get("companies") ?? "").split(",").filter((slug) => bySlug.has(slug)).slice(0, 4);
    let selected = fromQuery.length ? fromQuery : ["nvidia", "tsmc", "microsoft"];

    const element = <K extends keyof HTMLElementTagNameMap>(tag: K, className = "", text = "") => {
      const node = document.createElement(tag);
      if (className) node.className = className;
      if (text) node.textContent = text;
      return node;
    };

    const formatValue = (value: number, unit: string) => {
      const formatted = new Intl.NumberFormat("zh-CN", { notation: "compact", maximumFractionDigits: 2 }).format(value);
      return unit === "USD" ? `US$${formatted}` : `${formatted} ${unit}`.trim();
    };

    const readWatchlist = () => {
      try {
        const value = JSON.parse(localStorage.getItem(storageKey) ?? "[]");
        return Array.isArray(value) ? value.filter((slug) => bySlug.has(slug)) : [];
      } catch { return []; }
    };

    const addList = (parent: HTMLElement, title: string, values: string[], tone = "") => {
      const section = element("section", `compare-list ${tone}`);
      section.append(element("span", "compare-label", title));
      if (!values.length) {
        section.append(element("p", "compare-muted", "当前没有可展示条目。"));
        parent.append(section);
        return;
      }
      const list = element("ul");
      values.forEach((value) => list.append(element("li", "", value)));
      section.append(list);
      parent.append(section);
    };

    const renderColumn = (company: CompareCompany) => {
      const column = element("article", "compare-column");
      column.style.setProperty("--compare-accent", company.stage.accent);
      const head = element("header", "compare-column-head");
      const headTop = element("div", "compare-column-top");
      const meta = element("div", "compare-column-meta");
      meta.append(element("span", "", company.ticker), element("small", "", company.stage.name));
      const remove = element("button", "remove-company");
      remove.type = "button";
      remove.setAttribute("aria-label", `从比较中移除${company.name}`);
      remove.append(element("span", "", "×"), element("b", "", "移除"));
      remove.addEventListener("click", () => {
        selected = selected.filter((slug) => slug !== company.slug);
        render();
        defaultMessage();
      });
      headTop.append(meta, remove);
      head.append(headTop, element("h2", "", company.name), element("p", "", `${company.nameEn} · ${company.exchange}`));
      const dataStatus = company.dataStatus?.stale ? "上版快照" : company.dataStatus?.status === "ok" ? "数据最新" : company.dataStatus?.status === "manual" ? "人工维护" : "待配置";
      const status = element("small", `compare-data-status status-${company.dataStatus?.stale ? "stale" : company.dataStatus?.status ?? "pending"}`, dataStatus);
      head.append(status);
      column.append(head);

      const profile = element("section", "compare-profile");
      profile.append(element("span", "compare-label", "产业位置"), element("p", "", company.description));
      const tags = element("div", "compare-tags");
      company.focus.forEach((tag) => tags.append(element("span", "", tag)));
      profile.append(tags);
      column.append(profile);

      const metrics = element("section", "compare-metrics");
      metrics.append(element("span", "compare-label", "最新结构化指标"));
      if (company.metrics.length) {
        company.metrics.forEach((metric) => {
          const row = element("div", "compare-metric-row");
          const label = element("span", "", metric.name);
          const valueGroup = element("div", "compare-metric-value");
          const value = element("strong", "", formatValue(metric.value, metric.unit));
          const date = element("small", "", metric.periodEnd);
          if (metric.change !== null) {
            const change = element("b", metric.change >= 0 ? "up" : "down", `${metric.change >= 0 ? "+" : ""}${metric.change.toFixed(1)}%`);
            valueGroup.append(value, change, date);
          } else {
            valueGroup.append(value, date);
          }
          row.append(label, valueGroup);
          metrics.append(row);
        });
      } else metrics.append(element("p", "compare-muted", "当前市场暂无结构化指标。"));
      column.append(metrics);

      const filing = element("section", "compare-filing");
      filing.append(element("span", "compare-label", "最近官方披露"));
      if (company.latestFiling) {
        const link = element("a", "filing-card");
        link.href = company.latestFiling.url;
        link.target = "_blank";
        link.rel = "noreferrer";
        const filingTop = element("div");
        filingTop.append(element("strong", "", company.latestFiling.form), element("small", "", company.latestFiling.filedAt));
        link.append(filingTop, element("p", "", company.latestFiling.title), element("span", "", "打开 SEC 原文 ↗"));
        filing.append(link);
      } else filing.append(element("p", "compare-muted", "当前没有自动化官方披露。"));
      column.append(filing);

      const synthesis = element("section", "compare-analysis");
      synthesis.append(element("span", "compare-label", `AI 综合分析 · ${company.analysis?.confidence?.toUpperCase() ?? "N/A"}`), element("p", "", company.analysis?.summary ?? "等待证据。"));
      column.append(synthesis);
      addList(column, "需要继续跟踪", company.attention);
      addList(column, "风险与不确定性", company.risks, "risk");
      const detail = element("a", "compare-detail", "打开完整研究卡 →");
      detail.href = company.pageUrl;
      column.append(detail);
      return column;
    };

    const syncPickerControls = () => {
      if (!picker) return;
      const atStart = picker.scrollLeft <= 4;
      const atEnd = picker.scrollLeft + picker.clientWidth >= picker.scrollWidth - 4;
      if (pickerPrevious) pickerPrevious.disabled = atStart;
      if (pickerNext) pickerNext.disabled = atEnd;
    };

    const defaultMessage = () => {
      if (!message) return;
      message.textContent = selected.length < 2
        ? "再选择一家公司即可开始横向比较。"
        : selected.length === 4 ? "已选满四家公司，可移除后更换。" : `还可以选择 ${4 - selected.length} 家公司。`;
    };

    const render = () => {
      pickerButtons.forEach((button) => button.setAttribute("aria-pressed", String(selected.includes(button.dataset.compareCompany ?? ""))));
      if (selectionLabel) selectionLabel.textContent = selected.length ? `${selected.length} 家已选 · ${selected.map((slug) => bySlug.get(slug)?.name).filter(Boolean).join("、")}` : "尚未选择公司";
      if (selectionCount) selectionCount.textContent = String(selected.length);
      if (selectionChips) {
        const chips = selected.map((slug) => bySlug.get(slug)).filter((company): company is CompareCompany => Boolean(company)).map((company) => {
          const chip = element("button", "selection-chip");
          chip.type = "button";
          chip.setAttribute("aria-label", `从比较中移除${company.name}`);
          chip.append(element("span", "", company.ticker), document.createTextNode(company.name), element("i", "", "×"));
          chip.addEventListener("click", () => { selected = selected.filter((slug) => slug !== company.slug); render(); defaultMessage(); });
          return chip;
        });
        selectionChips.replaceChildren(...chips);
      }
      if (grid) {
        grid.replaceChildren(...selected.map((slug) => bySlug.get(slug)).filter((company): company is CompareCompany => Boolean(company)).map(renderColumn));
        grid.style.gridTemplateColumns = `repeat(${Math.max(selected.length, 1)}, minmax(18.5rem, 1fr))`;
        grid.style.minWidth = selected.length ? `max(100%, ${selected.length * 18.5 + Math.max(selected.length - 1, 0) * 0.75}rem)` : "100%";
      }
      empty?.classList.toggle("visible", selected.length === 0);
      const next = new URL(location.href);
      if (selected.length) next.searchParams.set("companies", selected.join(","));
      else next.searchParams.delete("companies");
      history.replaceState({}, "", next);
      requestAnimationFrame(syncPickerControls);
    };

    pickerButtons.forEach((button) => button.addEventListener("click", () => {
      const slug = button.dataset.compareCompany;
      if (!slug) return;
      if (selected.includes(slug)) selected = selected.filter((value) => value !== slug);
      else if (selected.length < 4) selected = [...selected, slug];
      else {
        if (message) message.textContent = "已选择四家公司，请先移除一家再添加。";
        return;
      }
      render();
      defaultMessage();
    }));

    search?.addEventListener("input", () => {
      const query = search.value.trim().toLowerCase();
      pickerButtons.forEach((button) => { button.hidden = Boolean(query) && !(button.dataset.search ?? "").includes(query); });
      picker?.scrollTo({ left: 0, behavior: "smooth" });
      requestAnimationFrame(syncPickerControls);
    });

    const scrollPicker = (direction: -1 | 1) => {
      if (!picker) return;
      picker.scrollBy({ left: direction * picker.clientWidth * 0.76, behavior: "smooth" });
    };

    pickerPrevious?.addEventListener("click", () => scrollPicker(-1));
    pickerNext?.addEventListener("click", () => scrollPicker(1));
    picker?.addEventListener("scroll", syncPickerControls, { passive: true });
    if (picker && "ResizeObserver" in window) new ResizeObserver(syncPickerControls).observe(picker);

    useWatchlist?.addEventListener("click", () => {
      const watched = readWatchlist().slice(0, 4);
      if (watched.length) selected = watched;
      if (message) message.textContent = watched.length ? `已载入 ${watched.length} 家关注公司。` : "关注列表为空，请先在公司目录添加。";
      render();
    });

    copyLink?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(location.href);
        copyLink.textContent = "已复制";
        setTimeout(() => { copyLink.textContent = "复制比较链接"; }, 1500);
      } catch { copyLink.textContent = "请复制地址栏链接"; }
    });
    render();
    defaultMessage();
  </script>
</BaseLayout>

<style is:global>
  .compare-hero {
    background: radial-gradient(circle at 76% 54%, rgba(167, 139, 250, 0.11), transparent 25rem);
    padding-bottom: 4rem;
    padding-top: 5.5rem;
  }

  .compare-hero .display-title { font-size: clamp(2.9rem, 5.4vw, 5.2rem); }
  .compare-workspace { padding: 2.6rem 0 6rem; }

  .picker-panel {
    background: linear-gradient(145deg, rgba(13, 29, 48, 0.92), rgba(7, 17, 30, 0.92));
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    box-shadow: 0 1.5rem 4rem rgba(0, 0, 0, 0.16);
    overflow: hidden;
    padding: 1.35rem;
    position: relative;
  }

  .picker-panel::before {
    background: linear-gradient(90deg, var(--mint), rgba(167, 139, 250, 0.55), transparent 72%);
    content: "";
    height: 1px;
    left: 1.35rem;
    position: absolute;
    right: 65%;
    top: 0;
  }

  .picker-head,
  .selection-summary { align-items: center; display: flex; gap: 2rem; justify-content: space-between; }
  .picker-head h2 { font-family: var(--font-display); font-size: 2rem; font-weight: 500; margin: 0.45rem 0 0; }
  .picker-actions { display: flex; flex-wrap: wrap; gap: 0.55rem; }
  .picker-actions button {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.76rem;
    padding: 0.58rem 0.8rem;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .picker-actions button:hover { background: rgba(99, 230, 190, 0.08); border-color: rgba(99, 230, 190, 0.35); color: var(--text-strong); transform: translateY(-1px); }
  .picker-actions button:focus-visible,
  .picker-nav:focus-visible,
  .company-picker button:focus-visible,
  .remove-company:focus-visible,
  .selection-chip:focus-visible { outline: 2px solid rgba(99, 230, 190, 0.72); outline-offset: 2px; }

  .compare-search { display: block; margin: 1.25rem 0 0.8rem; }
  .compare-search input {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    color: var(--text-strong);
    font-size: 0.86rem;
    outline: 0;
    padding: 0.9rem 1rem;
    transition: background 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
    width: 100%;
  }

  .compare-search input:focus { background: rgba(255, 255, 255, 0.04); border-color: rgba(99, 230, 190, 0.42); box-shadow: 0 0 0 3px rgba(99, 230, 190, 0.07); }

  .picker-rail {
    align-items: stretch;
    display: grid;
    gap: 0.55rem;
    grid-template-columns: 2.75rem minmax(0, 1fr) 2.75rem;
  }

  .picker-nav {
    align-items: center;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    color: var(--text-muted);
    display: flex;
    font-size: 1rem;
    justify-content: center;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
  }

  .picker-nav:hover:not(:disabled) { background: rgba(99, 230, 190, 0.08); border-color: rgba(99, 230, 190, 0.35); color: var(--mint); }
  .picker-nav:disabled { cursor: default; opacity: 0.24; }

  .company-picker {
    display: flex;
    gap: 0.55rem;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-behavior: smooth;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
  }

  .company-picker::-webkit-scrollbar { display: none; }
  .company-picker button {
    background: rgba(4, 13, 24, 0.38);
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    color: var(--text-muted);
    display: grid;
    flex: 0 0 11.25rem;
    gap: 0.28rem;
    justify-items: start;
    min-height: 6.65rem;
    padding: 0.8rem 2.3rem 0.8rem 0.85rem;
    position: relative;
    scroll-snap-align: start;
    text-align: left;
    transition: background 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .company-picker button:hover { background: rgba(255, 255, 255, 0.045); border-color: var(--line-strong); transform: translateY(-2px); }
  .company-picker button[hidden] { display: none; }
  .company-picker button[aria-pressed="true"] { background: linear-gradient(145deg, rgba(99, 230, 190, 0.13), rgba(83, 213, 245, 0.055)); border-color: rgba(99, 230, 190, 0.52); box-shadow: inset 0 0 0 1px rgba(99, 230, 190, 0.06), 0 0.8rem 2rem rgba(99, 230, 190, 0.08); }
  .company-picker button > span,
  .company-picker button > small { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.62rem; }
  .company-picker button > strong { color: var(--text-strong); font-size: 0.84rem; line-height: 1.3; }
  .company-picker button > i {
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 50%;
    color: var(--text-dim);
    display: flex;
    font-size: 0.75rem;
    font-style: normal;
    height: 1.45rem;
    justify-content: center;
    position: absolute;
    right: 0.7rem;
    top: 0.7rem;
    transition: background 160ms ease, color 160ms ease, transform 160ms ease;
    width: 1.45rem;
  }

  .company-picker button[aria-pressed="true"] > i { background: var(--mint); border-color: var(--mint); color: var(--bg-deep); transform: rotate(45deg); }

  .picker-foot { align-items: center; color: var(--text-dim); display: flex; font-size: 0.68rem; justify-content: space-between; margin-top: 0.75rem; }
  .picker-message { color: var(--text-muted); margin: 0; }

  .selection-summary { border-bottom: 1px solid var(--line); padding: 2rem 0 1.2rem; }
  .selection-summary > div:first-child { min-width: 0; }
  .selection-summary p { color: var(--text-muted); font-size: 0.84rem; margin: 0.45rem 0 0; }
  .selection-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.8rem; }
  .selection-chip {
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-muted);
    display: inline-flex;
    font-size: 0.7rem;
    gap: 0.4rem;
    padding: 0.35rem 0.45rem 0.35rem 0.6rem;
  }

  .selection-chip span { color: var(--mint); font-family: var(--font-mono); font-size: 0.6rem; }
  .selection-chip i { color: var(--text-dim); font-style: normal; font-size: 0.9rem; }
  .selection-chip:hover { border-color: rgba(255, 105, 135, 0.35); color: var(--text-strong); }
