---
import { sitePath } from "../lib/paths";
---

<a class="brand" href={sitePath("/")} aria-label="智芯图谱首页">
  <img class="brand-mark" src={sitePath("/favicon.svg")} alt="" width="34" height="34" />
  <span class="brand-copy">
    <strong>智芯图谱</strong>
    <small>AI & Silicon Atlas</small>
  </span>
</a>

<style>
  .brand {
    align-items: center;
    color: var(--text-strong);
    display: inline-flex;
    gap: 0.7rem;
    text-decoration: none;
  }

  .brand-mark {
    height: 2.1rem;
    transition: filter 240ms ease, transform 480ms cubic-bezier(0.22, 1, 0.36, 1);
    width: 2.1rem;
  }

  .brand:hover .brand-mark,
  .brand:focus-visible .brand-mark {
    filter: drop-shadow(0 0 0.7rem rgba(99, 230, 190, 0.34));
    transform: rotate(8deg) scale(1.06);
  }

  .brand-copy {
    display: grid;
    line-height: 1;
  }

  .brand-copy strong {
    font-size: 1rem;
    letter-spacing: 0.16em;
  }

  .brand-copy small {
    color: var(--text-dim);
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    margin-top: 0.28rem;
    text-transform: uppercase;
  }
</style>
